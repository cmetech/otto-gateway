# Binaries
/bin/
/dist/
otto-gateway
otto-gateway.exe
# Do not ignore the Go source directory that shares the binary name.
!/cmd/otto-gateway/

# Build / test output
*.test
*.out
coverage.*

# Golden-fixture mismatch artifacts (written by failing golden tests
# under any testdata/ directory; the .golden source files ARE tracked).
**/testdata/*.actual

# Go workspace files (local only)
go.work
go.work.sum

# Environment / secrets
.env
.env.*
!.env.example
!.env.*.example
*_creds*
private.*

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Caches / temp
tmp/
.tmp/

# Runtime log directory — rotated by the gateway via timberjack.
# Keep the directory in the tree (so the packaged layout works on fresh
# clones) but ignore the contents.
logs/*
!logs/.gitkeep

# Distribution archive staging (make package / make package-all output).
dist/
**/temp/

# Local Claude / Kiro state (skills + commands are versioned; runtime state is not)
.claude/settings.local.json
# Subagent worktree isolation state — created when Claude Code spawns
# Agent calls with isolation="worktree". These are throwaway git worktrees
# that get reaped on shutdown; never commit them.
.claude/worktrees/
.bg-shell/
.otto/

# E2E artifacts (generated; the SDK source files + pnpm-lock.yaml stay tracked)
tests/e2e/reports/
tests/e2e/sdk/node_modules/
# We standardize on pnpm — pnpm-lock.yaml is committed for reproducible installs.
# An npm-generated lockfile is not (use pnpm).
tests/e2e/sdk/package-lock.json
