# Binaries
/bin/
/dist/
loop24-gateway
loop24-gateway.exe
# Do not ignore the Go source directory that shares the binary name.
!/cmd/loop24-gateway/

# Build / test output
*.test
*.out
coverage.*

# Golden-fixture mismatch artifacts (written by failing golden tests
# under any testdata/ directory; the .golden source files ARE tracked).
**/testdata/*.actual

# Go workspace files (local only)
go.work
go.work.sum

# Environment / secrets
.env
.env.*
!.env.example
*_creds*
private.*

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Caches / temp
tmp/
.tmp/
**/temp/

# Local Claude / Kiro state (skills + commands are versioned; runtime state is not)
.claude/settings.local.json
