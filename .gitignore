# Binaries
/bin/
/dist/
otto-gateway
otto-gateway.exe
# Do not ignore the Go source directory that shares the binary name.
!/cmd/otto-gateway/

# Build / test output
*.test
*.out
coverage.*

# Golden-fixture mismatch artifacts (written by failing golden tests
# under any testdata/ directory; the .golden source files ARE tracked).
**/testdata/*.actual

# Go workspace files (local only)
go.work
go.work.sum

# Environment / secrets
.env
.env.*
!.env.example
*_creds*
private.*

# Editor / OS noise
.vscode/
.idea/
.DS_Store

# Caches / temp
tmp/
.tmp/
**/temp/

# Local Claude / Kiro state (skills + commands are versioned; runtime state is not)
.claude/settings.local.json

# E2E artifacts (generated; the SDK source files stay tracked)
tests/e2e/reports/
tests/e2e/sdk/node_modules/
# Opt-in harness lockfiles — version pinned in package.json; setup accepts pnpm or npm.
tests/e2e/sdk/pnpm-lock.yaml
tests/e2e/sdk/package-lock.json
