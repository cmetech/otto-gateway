{{define "content"}}<main class="otto-page">
  <section class="otto-card otto-about-identity">
    <h1 class="otto-about-wordmark">OTTO Gateway</h1>
    <p class="otto-about-tagline">LLM gateway with unified OpenAI / Ollama / Anthropic surfaces</p>
  </section>
  <section class="otto-about-grid">
    <article class="otto-card">
      <h2 class="otto-h2">Build Info</h2>
      <dl class="otto-about-dl">
        <dt>Version</dt><dd>{{.Version}}</dd>
        <dt>Commit</dt><dd>{{.Commit}}</dd>
        <dt>Go runtime</dt><dd>{{.GoVersion}}</dd>
        <dt>GOOS / GOARCH</dt><dd>{{.GOOS}} / {{.GOARCH}}</dd>
      </dl>
    </article>
    <article class="otto-card">
      <h2 class="otto-h2">Runtime Status</h2>
      <dl class="otto-about-dl">
        <dt>Started at</dt><dd>{{.StartedAt}}</dd>
        <dt>Listen address</dt><dd>{{.HTTPAddr}}</dd>
        <dt>Pool size</dt><dd>{{.PoolSize}}</dd>
        <dt>Session TTL</dt><dd>{{.SessionTTL}}</dd>
        <dt>Stream idle timeout</dt><dd>{{.StreamIdleDisplay}}</dd>
      </dl>
    </article>
    <article class="otto-card">
      <h2 class="otto-h2">Feature Flags</h2>
      <dl class="otto-about-dl">
        <dt>Auth</dt><dd>{{if .AuthEnabled}}on{{else}}off{{end}}</dd>
        <dt>IP allowlist</dt><dd>{{if .IPAllowlistEnabled}}on{{else}}off{{end}}</dd>
        <dt>Debug</dt><dd>{{if .Debug}}on{{else}}off{{end}}</dd>
        <dt>Chat trace</dt><dd>{{if .ChatTrace}}on <span class="otto-badge is-warning">SENSITIVE</span>{{else}}off{{end}}</dd>
      </dl>
    </article>
    <article class="otto-card">
      <h2 class="otto-h2">Upstream Worker</h2>
      <dl class="otto-about-dl">
        <dt>KIRO_CMD</dt><dd>{{.KiroCmd}}</dd>
        <dt>KIRO_ARGS</dt><dd>{{.KiroArgs}}</dd>
        <dt>KIRO_CWD</dt><dd>{{.KiroCwd}}</dd>
      </dl>
    </article>
    <article class="otto-card">
      <h2 class="otto-h2">Endpoints</h2>
      <dl class="otto-about-dl">
        <dt>Ollama prefix</dt><dd>{{.OllamaPathPrefix}}</dd>
        <dt>OpenAI prefix</dt><dd>{{.OpenAIPathPrefix}}</dd>
        <dt>Anthropic prefix</dt><dd>{{.AnthropicPathPrefix}}</dd>
        <dt>Admin</dt><dd>/admin/, /admin/api/snapshot, /admin/logs/stream</dd>
      </dl>
    </article>
    <article class="otto-card">
      <h2 class="otto-h2">Project Links</h2>
      <dl class="otto-about-dl">
        <dt>Repository</dt><dd><a href="https://github.com/cmetech/otto_app">github.com/cmetech/otto_app</a></dd>
        <dt>Documentation</dt><dd><a href="/admin/docs">/admin/docs</a></dd>
      </dl>
    </article>
  </section>
</main>{{end}}
{{template "base" .}}
