#!/usr/bin/env bash
# scripts/otto-gw — POSIX lifecycle manager for otto-gateway on macOS/Linux.
# Renamed from scripts/otto to avoid collision with the otto CLI binary.
#
# Subcommands:
#   start | stop | status | restart | logs [-f] | run | env
#
# Wrapper env overrides (where logs/pids/binary live):
#   OTTO_BIN, OTTO_PID, OTTO_LOG, OTTO_LOG_BOOT, OTTO_STATE_DIR, OTTO_ADDR
#
# Gateway config flags (for start | restart | run):
#   --pii MODE          off | replace | mask | hash | drop
#                         off → PII_REDACTION_ENABLED=false
#                         others → PII_REDACTION_ENABLED=true PII_REDACTION_MODE=MODE
#   --hash-key KEY      PII_HASH_KEY=KEY (required when --pii hash)
#   --entities LIST     PII_ENABLED_ENTITIES=LIST (e.g. Email,SSN)
#   --hooks LIST        ENABLED_HOOKS=LIST (allowlist; empty = all)
#   --auth TOKEN        AUTH_TOKEN=TOKEN
#
# .env loader (laptop-friendly persistence):
#   Loads the first match of:  ./.env.otto-gw  →  $HOME/.otto-gw.env
#   Override with --env-file PATH or OTTO_ENV_FILE=PATH.
#   CLI flags WIN over .env values; .env wins over inherited shell env
#   only for keys the .env actually sets.
set -euo pipefail

OTTO_BIN="${OTTO_BIN:-./bin/otto-gateway}"
# OTTO_PID lives under .otto/gw/ (project-local) rather than /tmp/ — some
# laptop setups (sandboxed shells, hardened tmp policies, network drives
# mapped to /tmp) make /tmp non-writable. The .otto/ namespace is shared
# with the OTTER client; we nest under gw/ to avoid name collisions.
OTTO_STATE_DIR="${OTTO_STATE_DIR:-./.otto/gw}"
OTTO_PID="${OTTO_PID:-${OTTO_STATE_DIR}/otto-gateway.pid}"
# OTTO_LOG = the structured rotated log the gateway owns (via timberjack).
# OTTO_LOG_BOOT = a small sidecar that captures crash output + kiro-cli
# stderr + any pre-logger panic — rarely consulted, invaluable on incident.
OTTO_LOG="${OTTO_LOG:-./logs/otto-gateway.log}"
OTTO_LOG_BOOT="${OTTO_LOG_BOOT:-${OTTO_LOG%.log}-boot.log}"
OTTO_ADDR="${OTTO_ADDR:-http://127.0.0.1:18080}"

# Default .env search order. First hit wins; --env-file or OTTO_ENV_FILE overrides.
DEFAULT_ENV_PATHS=("./.env.otto-gw" "$HOME/.otto-gw.env")

# resolve_env_file returns the path of the .env file to source, or empty.
# Honors --env-file override (already parsed into $ENV_FILE_OVERRIDE) and
# OTTO_ENV_FILE before falling back to DEFAULT_ENV_PATHS.
resolve_env_file() {
    if [[ -n "${ENV_FILE_OVERRIDE:-}" ]]; then
        echo "$ENV_FILE_OVERRIDE"
        return 0
    fi
    if [[ -n "${OTTO_ENV_FILE:-}" ]]; then
        echo "$OTTO_ENV_FILE"
        return 0
    fi
    for path in "${DEFAULT_ENV_PATHS[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    # No match — explicit return 0 keeps `set -e` callers safe.
    return 0
}

# load_env_file sources KEY=value lines from $1. Tolerates blank lines
# and # comments. Quoted values are honored. Does NOT execute arbitrary
# shell — we parse line-by-line and `export` each key explicitly so the
# .env file behaves as data, not code (no `$(...)` or backticks).
load_env_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local line key val
    while IFS= read -r line || [[ -n "$line" ]]; do
        # Strip leading whitespace.
        line="${line#"${line%%[![:space:]]*}"}"
        # Skip blanks and comments.
        [[ -z "$line" || "$line" == \#* ]] && continue
        # Strip optional leading "export ".
        line="${line#export }"
        # Must contain '='.
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"
        val="${line#*=}"
        # Strip surrounding single or double quotes (one layer only).
        if [[ "$val" == \"*\" ]] || [[ "$val" == \'*\' ]]; then
            val="${val:1:${#val}-2}"
        fi
        export "$key=$val"
    done < "$file"
}

# apply_cli_flags overrides exported vars with any --pii / --hash-key /
# etc. that came in on the command line. Called AFTER load_env_file so
# flags win.
apply_cli_flags() {
    if [[ -n "${FLAG_PII_MODE:-}" ]]; then
        if [[ "$FLAG_PII_MODE" == "off" ]]; then
            export PII_REDACTION_ENABLED="false"
        else
            export PII_REDACTION_ENABLED="true"
            export PII_REDACTION_MODE="$FLAG_PII_MODE"
        fi
    fi
    if [[ -n "${FLAG_HASH_KEY:-}" ]]; then export PII_HASH_KEY="$FLAG_HASH_KEY"; fi
    if [[ -n "${FLAG_ENTITIES:-}" ]]; then export PII_ENABLED_ENTITIES="$FLAG_ENTITIES"; fi
    if [[ -n "${FLAG_HOOKS:-}" ]];    then export ENABLED_HOOKS="$FLAG_HOOKS"; fi
    if [[ -n "${FLAG_AUTH:-}" ]];     then export AUTH_TOKEN="$FLAG_AUTH"; fi
    return 0
}

# parse_flags reads a remaining-args array (positional after the
# subcommand) and populates the FLAG_* globals + ENV_FILE_OVERRIDE.
# `--show-secrets` is only meaningful for the `env` subcommand but is
# parsed uniformly so callers can preview "what would happen with
# secrets visible." Anything not recognised → `unknown flag` exit.
parse_flags() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pii)           FLAG_PII_MODE="$2"; shift 2 ;;
            --pii=*)         FLAG_PII_MODE="${1#*=}"; shift ;;
            --hash-key)      FLAG_HASH_KEY="$2"; shift 2 ;;
            --hash-key=*)    FLAG_HASH_KEY="${1#*=}"; shift ;;
            --entities)      FLAG_ENTITIES="$2"; shift 2 ;;
            --entities=*)    FLAG_ENTITIES="${1#*=}"; shift ;;
            --hooks)         FLAG_HOOKS="$2"; shift 2 ;;
            --hooks=*)       FLAG_HOOKS="${1#*=}"; shift ;;
            --auth)          FLAG_AUTH="$2"; shift 2 ;;
            --auth=*)        FLAG_AUTH="${1#*=}"; shift ;;
            --env-file)      ENV_FILE_OVERRIDE="$2"; shift 2 ;;
            --env-file=*)    ENV_FILE_OVERRIDE="${1#*=}"; shift ;;
            --show-secrets)  FLAG_SHOW_SECRETS=1; shift ;;
            *)               echo "unknown flag: $1" >&2; exit 1 ;;
        esac
    done
}

# load_config is the standard pre-launch hook: resolve .env → source it
# → apply flag overrides. Idempotent; safe to call from start/restart/
# run/env.
load_config() {
    local env_file
    env_file="$(resolve_env_file)"
    if [[ -n "$env_file" ]]; then
        load_env_file "$env_file"
        echo "loaded env file: $env_file" >&2
        # Surface the resolved path to the gateway so it can log at INFO
        # which file the wrapper actually used. The binary reads this from
        # os.Getenv("OTTO_ENV_FILE_LOADED") at startup.
        export OTTO_ENV_FILE_LOADED="$env_file"
    fi
    apply_cli_flags
}

# preflight_kiro resolves KIRO_CMD before the gateway launches:
#   1. If KIRO_CMD is unset → auto-detect `kiro-cli` on PATH and silently
#      set KIRO_CMD. Surfaces a brief "auto-detected" line so the
#      operator sees what just happened without having to inspect
#      /api/version or the log.
#   2. If KIRO_CMD is set but doesn't resolve → warn (don't abort).
#   3. If KIRO_CMD is set and resolves → silent (happy path).
#
# Degraded boot (no kiro-cli found) is non-fatal because /health,
# /health/hooks, and /health/pool all work without it — operators may
# genuinely want a diagnostic-only run. Returns 0 always.
preflight_kiro() {
    local kiro="${KIRO_CMD:-}"
    if [[ -z "$kiro" ]]; then
        # Auto-detect before warning. command -v handles both absolute
        # paths (a hash-table lookup miss) and PATH resolution.
        local found
        found="$(command -v kiro-cli 2>/dev/null || true)"
        if [[ -n "$found" ]]; then
            export KIRO_CMD="$found"
            echo "  ✓  KIRO_CMD auto-detected: $found"
            return 0
        fi
        echo "  ⚠  KIRO_CMD is unset and 'kiro-cli' is not on PATH — gateway will boot but chat requests will return 503." >&2
        echo "     Install kiro-cli OR set KIRO_CMD in your .env (or shell)." >&2
        return 0
    fi
    # KIRO_CMD is set — validate it resolves to an executable. Try as
    # absolute path first (covers KIRO_CMD=/abs/path/to/kiro-cli); fall
    # back to PATH resolution (covers KIRO_CMD=kiro-cli).
    if [[ -x "$kiro" ]] || command -v "$kiro" >/dev/null 2>&1; then
        return 0
    fi
    echo "  ⚠  KIRO_CMD=\"$kiro\" does not resolve to an executable on PATH or as an absolute path." >&2
    echo "     Gateway will boot but chat requests will return 503 until this is fixed." >&2
    return 0
}

# wait_until_ready polls ${OTTO_ADDR}/health up to $1 seconds (default 5).
# Returns 0 on first 2xx; 1 on timeout or non-2xx after all retries.
# Silent on success; on failure tails the last 20 lines of the boot
# sidecar so the operator sees why the gateway never came up.
wait_until_ready() {
    local timeout_s="${1:-5}"
    if ! command -v curl >/dev/null 2>&1; then
        # No curl → skip the probe entirely. Operator can `status` manually.
        return 0
    fi
    local deadline=$(( $(date +%s) + timeout_s ))
    while (( $(date +%s) < deadline )); do
        if curl -sf -m 1 "${OTTO_ADDR}/health" >/dev/null 2>&1; then
            return 0
        fi
        # Also bail early if the binary already exited (PID file's pid is dead).
        if [[ -f "$OTTO_PID" ]]; then
            local p; p=$(cat "$OTTO_PID")
            if ! kill -0 "$p" 2>/dev/null; then
                break
            fi
        fi
        sleep 0.25
    done
    return 1
}

start() {
    if [[ -f "$OTTO_PID" ]]; then
        local pid
        pid=$(cat "$OTTO_PID")
        if kill -0 "$pid" 2>/dev/null; then
            echo "otto-gateway is already running (PID $pid)" >&2
            exit 1
        fi
        rm -f "$OTTO_PID"
    fi
    load_config
    # Ensure the log + state directories exist before launch. Supports
    # both the packaged otto_gateway/{logs,.otto/gw}/ layout and any
    # custom OTTO_LOG / OTTO_PID paths the operator set.
    local log_dir state_dir
    log_dir="$(dirname "$OTTO_LOG")"
    if [[ -n "$log_dir" && "$log_dir" != "." ]]; then
        mkdir -p "$log_dir"
    fi
    state_dir="$(dirname "$OTTO_PID")"
    if [[ -n "$state_dir" && "$state_dir" != "." ]]; then
        mkdir -p "$state_dir"
    fi
    # Gateway env vars are inherited from the current environment
    # automatically — no explicit forwarding needed. Documented set:
    #   KIRO_CMD, KIRO_ARGS, KIRO_CWD           — kiro-cli subprocess wiring
    #   DEBUG, HTTP_ADDR, PING_INTERVAL         — runtime knobs
    #   AUTH_TOKEN, ALLOWED_IPS                 — auth + IP allowlist (Phase 2)
    #   AUTH_TRUST_XFF                          — opt-in XFF trust (Codex H-7)
    #   POOL_SIZE                               — warm-pool size (Phase 2)
    #   OLLAMA_PATH_PREFIX, OPENAI_PATH_PREFIX  — route prefixes
    #   ENABLED_HOOKS, PII_REDACTION_ENABLED,   — Phase 8 hook chain knobs
    #   PII_ENABLED_ENTITIES, PII_REDACTION_MODE,
    #   PII_HASH_KEY
    #   LOG_FILE                                — daily-rotated log path (timberjack)
    # LOG_FILE points the gateway's structured slog output at the rotated
    # log. nohup's redirect then captures only stderr / pre-logger output /
    # crash trails into the small boot sidecar.
    export LOG_FILE="$OTTO_LOG"
    preflight_kiro
    nohup "$OTTO_BIN" >> "$OTTO_LOG_BOOT" 2>&1 &
    echo $! > "$OTTO_PID"
    echo "otto-gateway starting (PID $(cat "$OTTO_PID"))…"
    echo "  log:      $OTTO_LOG (rotated daily, 7d retention)"
    echo "  boot/err: $OTTO_LOG_BOOT"
    # Block briefly until /health returns 2xx so the operator sees the
    # actual ready/failed verdict instead of a phantom "running" PID
    # they only discover is dead on the next subcommand.
    #
    # The 10s budget covers a normal boot (sub-second on a working kiro)
    # and most warmup paths. A broken KIRO_CMD takes the gateway's
    # warmupDeadline (30s) to fail; the readiness probe will time out
    # before that and surface the partial structured-log tail so the
    # operator sees what's wrong without waiting the full 30s.
    if wait_until_ready 10; then
        echo "  ready:    ${OTTO_ADDR}/health"
    else
        echo "  ❌  gateway did NOT become ready within 10s." >&2
        # Prefer the structured log (where slog calls go when LOG_FILE
        # is set) and fall back to the boot sidecar (where pre-logger
        # / Go runtime / kiro-cli stderr lands).
        local source_log=""
        if [[ -s "$OTTO_LOG" ]]; then
            source_log="$OTTO_LOG"
        elif [[ -s "$OTTO_LOG_BOOT" ]]; then
            source_log="$OTTO_LOG_BOOT"
        fi
        if [[ -n "$source_log" ]]; then
            echo "     Last 20 lines of $source_log:" >&2
            tail -n 20 "$source_log" | sed 's/^/       /' >&2
        else
            echo "     (both log files are empty — likely a hung warmup; check KIRO_CMD)" >&2
        fi
        exit 1
    fi
}

stop() {
    if [[ ! -f "$OTTO_PID" ]]; then
        echo "otto-gateway is not running (no PID file)" >&2
        exit 1
    fi
    local pid
    pid=$(cat "$OTTO_PID")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "otto-gateway: stopped (stale PID)"
        rm -f "$OTTO_PID"
        exit 0
    fi
    kill "$pid"
    # Wait for the process to exit before removing the PID file.
    # This eliminates the restart race (Codex MEDIUM fix).
    local i=0
    while kill -0 "$pid" 2>/dev/null && [[ "$i" -lt 100 ]]; do
        sleep 0.1
        i=$((i + 1))
    done
    rm -f "$OTTO_PID"
    echo "otto-gateway stopped"
}

status() {
    if [[ ! -f "$OTTO_PID" ]]; then
        echo "otto-gateway: stopped"
        exit 1
    fi
    local pid
    pid=$(cat "$OTTO_PID")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "otto-gateway: stopped (stale PID)"
        exit 1
    fi
    echo "otto-gateway: running (PID $pid)"
    if command -v curl >/dev/null 2>&1; then
        curl -sf "${OTTO_ADDR}/health" 2>/dev/null | python3 -m json.tool 2>/dev/null || true
    fi
}

restart() {
    stop
    start
}

logs() {
    local follow="${1:-}"
    if [[ "$follow" == "-f" ]]; then
        tail -f "$OTTO_LOG"
    else
        tail -n 50 "$OTTO_LOG"
    fi
}

run() {
    load_config
    # Foreground execution — inherits all env vars from the calling shell.
    exec "$OTTO_BIN"
}

# show_version delegates to the binary's --version handler so the wrapper
# and the binary cannot disagree. The version string is the same one
# baked into the binary at build time via the Makefile's `-X` ldflag.
show_version() {
    if [[ ! -x "$OTTO_BIN" ]]; then
        echo "Error: $OTTO_BIN not found or not executable." >&2
        exit 1
    fi
    "$OTTO_BIN" --version
}

# gen_random_hex N → 2*N hex characters from a CSPRNG. Prefers openssl
# (universally present on macOS, package-available on Linux); falls back
# to /dev/urandom + od for minimalist environments.
gen_random_hex() {
    local nbytes="${1:-32}"
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex "$nbytes"
    elif [[ -r /dev/urandom ]]; then
        head -c "$nbytes" /dev/urandom | od -An -vtx1 | tr -d ' \n'
    else
        echo "ERROR: no CSPRNG available (need openssl or /dev/urandom)" >&2
        return 1
    fi
}

# init writes a starter .env file populated with sensible defaults and
# freshly-generated AUTH_TOKEN + PII_HASH_KEY. Designed as the very
# first command a new operator runs after extracting the tarball.
#
# Flags (all optional; unspecified values are prompted interactively
# unless --non-interactive is passed):
#   --dest PATH         where to write (default: $HOME/.otto-gw.env)
#   --here              shortcut for --dest ./.env.otto-gw
#   --force             overwrite if dest exists
#   --auth-token TOK    use TOK instead of generating
#   --hash-key KEY      use KEY instead of generating
#   --kiro PATH         KIRO_CMD value
#   --addr ADDR         HTTP_ADDR value (default 127.0.0.1:18080)
#   --pii MODE          off|replace|mask|hash|drop  (default off)
#   --auth-enabled      enable bearer-token auth (default off; AUTH_TOKEN
#                       line is pregenerated but written commented when
#                       disabled so flipping a '#' enables it later)
#   --non-interactive   don't prompt; use defaults for anything unset
init_cmd() {
    local dest="${HOME}/.otto-gw.env"
    local force=0
    local non_interactive=0
    local arg_auth_token="" arg_hash_key="" arg_kiro="" arg_addr="" arg_pii=""
    local arg_auth_enabled=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dest)              dest="$2"; shift 2 ;;
            --dest=*)            dest="${1#*=}"; shift ;;
            --here)              dest="./.env.otto-gw"; shift ;;
            --force)             force=1; shift ;;
            --non-interactive)   non_interactive=1; shift ;;
            --auth-enabled)      arg_auth_enabled=1; shift ;;
            --auth-token)        arg_auth_token="$2"; arg_auth_enabled=1; shift 2 ;;
            --auth-token=*)      arg_auth_token="${1#*=}"; arg_auth_enabled=1; shift ;;
            --hash-key)          arg_hash_key="$2"; shift 2 ;;
            --hash-key=*)        arg_hash_key="${1#*=}"; shift ;;
            --kiro)              arg_kiro="$2"; shift 2 ;;
            --kiro=*)            arg_kiro="${1#*=}"; shift ;;
            --addr)              arg_addr="$2"; shift 2 ;;
            --addr=*)            arg_addr="${1#*=}"; shift ;;
            --pii)               arg_pii="$2"; shift 2 ;;
            --pii=*)             arg_pii="${1#*=}"; shift ;;
            *)                   echo "init: unknown flag: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -e "$dest" && "$force" -ne 1 ]]; then
        echo "ERROR: $dest already exists. Re-run with --force to overwrite." >&2
        exit 1
    fi

    # Generate secrets (--auth-token / --hash-key override).
    local auth_token="$arg_auth_token"
    [[ -z "$auth_token" ]] && auth_token="$(gen_random_hex 32)"
    local hash_key="$arg_hash_key"
    [[ -z "$hash_key" ]] && hash_key="$(gen_random_hex 32)"

    # Resolve KIRO_CMD — flag → interactive prompt → suggest `command -v kiro-cli`.
    local kiro_cmd="$arg_kiro"
    if [[ -z "$kiro_cmd" && "$non_interactive" -ne 1 ]]; then
        local kiro_default; kiro_default="$(command -v kiro-cli 2>/dev/null || true)"
        read -r -p "  kiro-cli path [${kiro_default:-press Enter to leave unset}]: " kiro_cmd
        [[ -z "$kiro_cmd" ]] && kiro_cmd="$kiro_default"
    fi

    # Resolve HTTP_ADDR — flag → prompt with Ollama-compat callout.
    local http_addr="$arg_addr"
    if [[ -z "$http_addr" && "$non_interactive" -ne 1 ]]; then
        echo "  HTTP listen address — default 127.0.0.1:18080 (safe, no collision)."
        echo "  Set to 127.0.0.1:11434 if migrating from the Node Ollama proxy."
        read -r -p "  HTTP_ADDR [127.0.0.1:18080]: " http_addr
    fi
    [[ -z "$http_addr" ]] && http_addr="127.0.0.1:18080"

    # Resolve PII mode — flag → prompt → default off.
    local pii_mode="$arg_pii"
    if [[ -z "$pii_mode" && "$non_interactive" -ne 1 ]]; then
        echo "  PII redaction -- off | replace | mask | hash | drop."
        echo "  Pick 'replace' for human-readable redaction; 'hash' for log correlation."
        read -r -p "  PII mode [off]: " pii_mode
    fi
    [[ -z "$pii_mode" ]] && pii_mode="off"

    local pii_enabled="false"
    [[ "$pii_mode" != "off" ]] && pii_enabled="true"
    # If PII mode != hash, pii_hash_key is still written (commented? no, harmless to set)
    # so the operator can switch to hash mode later without re-running init.

    # Resolve AUTH mode -- flag (--auth-enabled / --auth-token) → prompt → default off.
    # When disabled, AUTH_TOKEN is still pregenerated but the line is written
    # commented out so the operator can enable it later by deleting the leading
    # '#' without re-running init.
    local auth_enabled="$arg_auth_enabled"
    if [[ "$auth_enabled" -eq 0 && "$non_interactive" -ne 1 ]]; then
        echo "  Bearer-token auth -- when enabled, every request must carry"
        echo "  'Authorization: Bearer <token>'. Off is fine for local/laptop use."
        read -r -p "  Enable auth? [y/N]: " auth_reply
        case "$auth_reply" in
            [Yy]|[Yy][Ee][Ss]) auth_enabled=1 ;;
            *) auth_enabled=0 ;;
        esac
    fi
    local auth_token_prefix=""
    if [[ "$auth_enabled" -ne 1 ]]; then
        auth_token_prefix="# "
    fi

    # Ensure parent dir exists.
    local dest_dir; dest_dir="$(dirname "$dest")"
    [[ -n "$dest_dir" && "$dest_dir" != "." ]] && mkdir -p "$dest_dir"

    # Write the .env file. cat-heredoc with quoted EOF so values are
    # literal (no shell expansion).
    cat > "$dest" <<EOF
# Generated by 'otto-gw init' on $(date -u +%Y-%m-%dT%H:%M:%SZ)
# Edit any value; restart the gateway to apply.

# Bearer token clients must send as Authorization: Bearer <token>.
# Default is auth DISABLED (line commented) -- delete the leading '#' to
# enable. Token is pregenerated so you can enable without re-running init.
${auth_token_prefix}AUTH_TOKEN=$auth_token

# kiro-cli subprocess wiring. Without this set, chat requests return 503.
KIRO_CMD=$kiro_cmd

# HTTP listen address. Default 127.0.0.1:18080; use :11434 for Ollama compat.
HTTP_ADDR=$http_addr

# --- Phase 8 hook chain -----------------------------------------------------
# Empty ENABLED_HOOKS = all hooks run in registration order. Comma-list to
# allowlist (unknown names cause boot failure -- typo protection). The four
# hooks below are the day-one shipped set; edit to subset for diagnostics.
ENABLED_HOOKS=RequestIDHook,AuthHook,PIIRedactionHook,LoggingHook

PII_REDACTION_ENABLED=$pii_enabled
PII_REDACTION_MODE=$pii_mode

# HMAC-SHA256 key for hash mode. Pre-generated for you; rotate to break
# attacker log correlation if you suspect a key leak.
PII_HASH_KEY=$hash_key

# Empty = all six recognizers (Email, IPv4, IPv6, SSN, CreditCard, USPhone).
# PII_ENABLED_ENTITIES=Email,SSN,CreditCard

# --- Misc -------------------------------------------------------------------
# DEBUG=true
# ALLOWED_IPS=127.0.0.1,::1
# AUTH_TRUST_XFF=false
# POOL_SIZE=2
EOF

    chmod 600 "$dest"

    echo "✓ wrote $dest (mode 0600)"
    if [[ "$auth_enabled" -eq 1 ]]; then
        echo "  AUTH:          enabled (AUTH_TOKEN=$(echo "$auth_token" | head -c 8)…)"
    else
        echo "  AUTH:          disabled (AUTH_TOKEN line commented; pregenerated token in file)"
    fi
    echo "  PII_HASH_KEY:  $(echo "$hash_key" | head -c 8)…(generated)"
    [[ -n "$kiro_cmd" ]] && echo "  KIRO_CMD:      $kiro_cmd" || echo "  KIRO_CMD:      (unset -- chat will 503 until you set it)"
    echo "  HTTP_ADDR:     $http_addr"
    echo "  PII:           $pii_mode"
    echo ""
    echo "Next: ./scripts/otto-gw start"
}

# env subcommand: print the resolved gateway-relevant env (KEY=value, one
# per line). Secrets are masked unless --show-secrets is passed.
print_env() {
    load_config
    local show_secrets="${FLAG_SHOW_SECRETS:-0}"
    local k v masked
    for k in ENABLED_HOOKS PII_REDACTION_ENABLED PII_REDACTION_MODE \
             PII_ENABLED_ENTITIES PII_HASH_KEY AUTH_TOKEN ALLOWED_IPS \
             AUTH_TRUST_XFF HTTP_ADDR KIRO_CMD KIRO_ARGS KIRO_CWD \
             POOL_SIZE DEBUG; do
        v="${!k:-}"
        if [[ -z "$v" ]]; then
            continue
        fi
        if [[ "$show_secrets" != "1" ]] && [[ "$k" == "AUTH_TOKEN" || "$k" == "PII_HASH_KEY" ]]; then
            # Show only first 4 chars + char count, never the literal.
            masked="${v:0:4}…(${#v} chars)"
            echo "$k=$masked"
        else
            echo "$k=$v"
        fi
    done
}

usage() {
    cat >&2 <<'EOF'
Usage: otto-gw <command> [flags]

Commands:
  init [flags]        First-run setup — generates AUTH_TOKEN + PII_HASH_KEY,
                      prompts for KIRO_CMD + HTTP_ADDR, writes a .env file.
  start [flags]       Start gateway in background (waits for /health)
  stop                Stop background gateway
  status              Show gateway status and health
  restart [flags]     Stop then start (re-applies flags / .env)
  logs [-f]           Tail gateway log (optional -f to follow)
  run [flags]         Run gateway in foreground
  env [--show-secrets]
                      Print the resolved gateway env that would be passed
  version             Print the gateway binary version (delegates to bin/otto-gateway --version)

Gateway config flags (for start | restart | run | env):
  --pii MODE          off | replace | mask | hash | drop
  --hash-key KEY      PII_HASH_KEY (required when --pii hash)
  --entities LIST     PII_ENABLED_ENTITIES (comma list)
  --hooks LIST        ENABLED_HOOKS allowlist (comma list, empty = all)
  --auth TOKEN        AUTH_TOKEN
  --env-file PATH     Override the default .env search

init flags:
  --dest PATH         where to write the .env (default $HOME/.otto-gw.env)
  --here              shortcut for --dest ./.env.otto-gw
  --force             overwrite if dest exists
  --kiro PATH         skip the KIRO_CMD prompt
  --addr ADDR         skip the HTTP_ADDR prompt (default 127.0.0.1:18080)
  --pii MODE          skip the PII prompt (default off)
  --auth-enabled      enable bearer-token auth (default off; AUTH_TOKEN line
                      pregenerated but commented when disabled, so flipping
                      the '#' enables it without re-running init)
  --auth-token TOK    use TOK instead of generating (implies --auth-enabled)
  --hash-key KEY      use KEY instead of generating
  --non-interactive   don't prompt; use defaults for unspecified values

.env auto-load search:
  1. --env-file PATH                  (CLI override)
  2. $OTTO_ENV_FILE                   (env override)
  3. ./.env.otto-gw                   (project-local)
  4. $HOME/.otto-gw.env               (per-user)

Precedence (highest first): CLI flag → .env file → inherited shell env.

See scripts/.env.otto-gw.example for a starter template.
EOF
    exit 1
}

CMD="${1:-}"
if [[ -n "$CMD" ]]; then shift; fi
case "$CMD" in
    start|restart|run|env)
        parse_flags "$@"
        case "$CMD" in
            start)   start ;;
            restart) restart ;;
            run)     run ;;
            env)     print_env ;;
        esac
        ;;
    init)    init_cmd "$@" ;;
    stop)    stop ;;
    status)  status ;;
    logs)    logs "${1:-}" ;;
    version) show_version ;;
    *)       usage ;;
esac
