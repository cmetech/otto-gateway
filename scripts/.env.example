# scripts/.env.example
# This is the TEMPLATE. gw copies it byte-for-byte to .env on init
# and upgrade-env. Operator customizations live in overrides.env, which
# is loaded SECOND so its values win.
#
# To set a value, edit overrides.env (or rerun `gw init`).
# DO NOT edit .env -- it is overwritten on every `gw upgrade-env`.
#
# Syntax: KEY=value, one per line. # = comment. `export KEY=value` also tolerated.
# Quoted values strip ONE layer of single or double quotes. No `$(...)` or
# variable expansion -- the loader parses as data, not shell.

# --- Required for any chat call ---------------------------------------------
# Bearer token clients must send as `Authorization: Bearer <token>`.
# Comma-separated for multiple valid tokens (e.g. rotation).
# Commented = auth DISABLED (the out-of-box default). Uncomment and set a
# real token to require Bearer auth on every request.
# AUTH_TOKEN=replace-me

# --- kiro-cli subprocess wiring ---------------------------------------------
# Absolute path or PATH-resolvable binary name. Empty = chat returns 503 until
# set. KIRO_ARGS / KIRO_CWD are optional.
KIRO_CMD=
# KIRO_ARGS=--profile=default
# KIRO_CWD=/tmp/otto-kiro

# --- Listener ---------------------------------------------------------------
HTTP_ADDR=127.0.0.1:18080
# POOL_SIZE=2

# --- Stream idle watchdog -------------------------------------------------
# Server-side idle timeout (in seconds) for the chunk-receive loop. If kiro
# produces no chunks within this window, the gateway tears down the stream,
# emits a terminal error frame to the client, and frees the pool slot.
# Default 30. Set to 0 to disable (legacy hang-forever behavior). Negative
# or non-integer values cause a boot error.
# STREAM_IDLE_TIMEOUT_SEC=30

# --- Phase 8 hook chain -----------------------------------------------------
# ENABLED_HOOKS: empty (the default) = run every registered hook in
# registration order. Uncomment + narrow ONLY if you want to disable specific
# hooks; the gateway refuses to start if any listed name is unknown
# (typo-fail-fast). ChatTraceHook is added automatically when CHAT_TRACE=true
# and must appear in this list when chat-trace is enabled.
#
# Default chain (all 5 hooks): RequestIDHook, AuthHook,
# JSONFormatSteeringHook, PIIRedactionHook, LoggingHook.
# ENABLED_HOOKS=RequestIDHook,AuthHook,JSONFormatSteeringHook,PIIRedactionHook,LoggingHook

# Master switch for PII redaction. Hook is present in the chain regardless,
# but inert until this is true (two-knob design: ENABLED_HOOKS = presence,
# PII_REDACTION_ENABLED = work-doing).
PII_REDACTION_ENABLED=true

# Comma list from {Email, IPv4, IPv6, SSN, CreditCard, USPhone, SIP_URI,
# IMEI, IMSI, MSISDN, MAC_ADDRESS, COORDINATES, SITE, PERSON, LOCATION}.
# Empty = all registered recognizers. PERSON / LOCATION require
# PII_NER_ENABLED=true to actually fire.
# PII_ENABLED_ENTITIES=Email,SSN,CreditCard

# replace | mask | hash | drop | encrypt. Default is encrypt: PII flows to
# the LLM as AES-256-GCM ciphertext (with the entity name bound as AAD)
# and is decrypted back to plaintext before the client sees the response
# (round-trip). 'hash' substitutes per-install HMAC tags so the same value
# correlates across log lines; 'replace' is human-readable; 'drop' removes
# the value entirely; 'mask' partially obfuscates. Streaming is auto-
# disabled when encrypt is active (the Pre hook flips Stream=false and
# adapters re-route to the aggregated path).
PII_REDACTION_MODE=encrypt

# REQUIRED when PII_REDACTION_MODE=hash (boot error otherwise). Real installs
# mint a unique 32-byte key at `gw init`; this placeholder marks the key
# as active-by-default. Rotating it invalidates prior correlation tokens.
PII_HASH_KEY=replace-with-32-byte-secret-key-here

# REQUIRED when PII_REDACTION_MODE=encrypt (the default) OR any entity in
# PII_ENTITY_ACTIONS uses :encrypt (boot error otherwise — the gateway names
# the env var in the fatal log). Any non-empty string; the gateway derives a
# 32-byte AES-256-GCM key via SHA-256 at boot. `gw init` now auto-mints
# this key alongside AUTH_TOKEN and PII_HASH_KEY; --regenerate-secrets rotates
# all three. Rotating invalidates every prior encrypted token (decrypt-on-
# response will fail), so treat rotation as a breaking change for any
# in-flight conversation history that round-trips.
PII_ENCRYPT_KEY=replace-with-any-non-empty-string

# Master switch for the prose-based NER recognizer (emits PERSON and
# LOCATION spans alongside the regex recognizers). Default true means
# the bundled averaged-perceptron model lazy-loads on first request.
# Set to false to skip the model load entirely (~7 MB binary impact is
# baked into the build either way; the runtime cost is the toggle).
PII_NER_ENABLED=true

# Per-entity action override map. Empty (the default) means every recognizer
# uses the global PII_REDACTION_MODE above. When set, the listed entities use
# the named action; unlisted entities fall back to the global mode. Allowed
# actions: replace | mask | hash | drop | encrypt. Boot error on unknown
# entity name or unknown action.
#
# Example: hash everything globally, but encrypt Email for transparent
# round-trip while dropping SSN entirely from the worker's view.
#   PII_REDACTION_MODE=hash
#   PII_ENTITY_ACTIONS=Email:encrypt,SSN:drop
# PII_ENTITY_ACTIONS=

# ------------------------------------------------------------------------------
# Chat-trace NDJSON tracer (raw user content -- sensitive!)
# ------------------------------------------------------------------------------
# When enabled, every chat-shaped request writes two NDJSON lines to a
# dedicated chat-trace.log: one stage="pre_chain_in" record capturing the
# post-adapter canonical request BEFORE PII redaction runs (so you see what
# the client actually said, raw), and one stage="post_chain_out" record on
# completion. Records share the same request_id so an operator can grep the
# two lines together.
#
# SECURITY WARNING: the chat-trace.log file contains raw user prompts
# including any PII the client sent. It is created with mode 0o600
# (owner-only) by default. DO NOT ship this file to centralized log
# aggregators without a redaction sidecar.
#
# CHAT_TRACE=false (default) means no file is opened on disk and no
# records are written. Flip to true ONLY when you need to debug a specific
# client's prompt shape.
# CHAT_TRACE=false

# Output file path. Default is sibling-to-LOG_FILE: same directory, base
# name + "-chat-trace.log". When LOG_FILE is unset, default is
# ./logs/gateway-chat-trace.log.
# CHAT_TRACE_FILE=./logs/gateway-chat-trace.log

# Days to retain rotated chat-trace logs. timberjack rotates daily at
# 00:00 local time with gzip compression; old archives are pruned by
# mtime age. Default 3 days bounds the sensitive-content exposure window.
# CHAT_TRACE_MAX_AGE_DAYS=3

# --- Misc -------------------------------------------------------------------
# DEBUG=true
# ALLOWED_IPS=127.0.0.1,::1
# AUTH_TRUST_XFF=false
