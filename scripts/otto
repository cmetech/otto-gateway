#!/usr/bin/env bash
# scripts/otto — POSIX lifecycle manager for otto-gateway on macOS/Linux.
# Subcommands: start | stop | status | restart | logs [-f] | run
# Env overrides: OTTO_BIN, OTTO_PID, OTTO_LOG, OTTO_ADDR
set -euo pipefail

OTTO_BIN="${OTTO_BIN:-./bin/otto-gateway}"
OTTO_PID="${OTTO_PID:-/tmp/otto-gateway.pid}"
OTTO_LOG="${OTTO_LOG:-/tmp/otto-gateway.log}"
OTTO_ADDR="${OTTO_ADDR:-http://localhost:11435}"

start() {
    if [[ -f "$OTTO_PID" ]]; then
        local pid
        pid=$(cat "$OTTO_PID")
        if kill -0 "$pid" 2>/dev/null; then
            echo "otto-gateway is already running (PID $pid)" >&2
            exit 1
        fi
        rm -f "$OTTO_PID"
    fi
    # Gateway env vars are inherited from the current environment
    # automatically — no explicit forwarding needed. Documented set
    # (Plan 02-06 wrapper expansion):
    #   KIRO_CMD, KIRO_ARGS, KIRO_CWD     — kiro-cli subprocess wiring
    #   DEBUG, HTTP_ADDR, PING_INTERVAL  — runtime knobs
    #   AUTH_TOKEN, ALLOWED_IPS           — auth + IP allowlist (Phase 2)
    #   AUTH_TRUST_XFF                    — opt-in XFF trust (Codex H-7)
    #   POOL_SIZE                         — warm-pool size (Phase 2)
    #   OLLAMA_PATH_PREFIX                — Ollama route prefix (default /api)
    #   OPENAI_PATH_PREFIX                — OpenAI route prefix (Phase 3 forward seam)
    nohup "$OTTO_BIN" >> "$OTTO_LOG" 2>&1 &
    echo $! > "$OTTO_PID"
    echo "otto-gateway started (PID $(cat "$OTTO_PID"))"
}

stop() {
    if [[ ! -f "$OTTO_PID" ]]; then
        echo "otto-gateway is not running (no PID file)" >&2
        exit 1
    fi
    local pid
    pid=$(cat "$OTTO_PID")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "otto-gateway: stopped (stale PID)"
        rm -f "$OTTO_PID"
        exit 0
    fi
    kill "$pid"
    # Wait for the process to exit before removing the PID file.
    # This eliminates the restart race (Codex MEDIUM fix).
    local i=0
    while kill -0 "$pid" 2>/dev/null && [[ "$i" -lt 100 ]]; do
        sleep 0.1
        i=$((i + 1))
    done
    rm -f "$OTTO_PID"
    echo "otto-gateway stopped"
}

status() {
    if [[ ! -f "$OTTO_PID" ]]; then
        echo "otto-gateway: stopped"
        exit 1
    fi
    local pid
    pid=$(cat "$OTTO_PID")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "otto-gateway: stopped (stale PID)"
        exit 1
    fi
    echo "otto-gateway: running (PID $pid)"
    if command -v curl >/dev/null 2>&1; then
        curl -sf "${OTTO_ADDR}/health" 2>/dev/null | python3 -m json.tool 2>/dev/null || true
    fi
}

restart() {
    stop
    start
}

logs() {
    local follow="${1:-}"
    if [[ "$follow" == "-f" ]]; then
        tail -f "$OTTO_LOG"
    else
        tail -n 50 "$OTTO_LOG"
    fi
}

run() {
    # Foreground execution — inherits all env vars from the calling shell.
    exec "$OTTO_BIN"
}

usage() {
    echo "Usage: $(basename "$0") <command>" >&2
    echo "" >&2
    echo "Commands:" >&2
    echo "  start       Start gateway in background" >&2
    echo "  stop        Stop background gateway" >&2
    echo "  status      Show gateway status and health" >&2
    echo "  restart     Stop then start" >&2
    echo "  logs [-f]   Tail gateway log (optional -f to follow)" >&2
    echo "  run         Run gateway in foreground" >&2
    exit 1
}

CMD="${1:-}"
case "$CMD" in
    start)   start ;;
    stop)    stop ;;
    status)  status ;;
    restart) restart ;;
    logs)    logs "${2:-}" ;;
    run)     run ;;
    *)       usage ;;
esac
