#!/usr/bin/env bash
# scripts/gw — POSIX lifecycle manager for the gateway on macOS/Linux.
# Renamed from scripts/otto to avoid collision with the otto CLI binary.
#
# Subcommands:
#   start | stop | status | restart | logs [-f] | run | env
#
# Wrapper env overrides (where logs/pids/binary live):
#   GW_BIN, GW_PID, GW_LOG, GW_LOG_BOOT, GW_STATE_DIR, GW_ADDR, GW_HOME,
#   GW_INSTALL_DIR
#
# Gateway config flags (for start | restart | run):
#   --pii MODE          off | replace | mask | hash | drop | encrypt
#                         off → PII_REDACTION_ENABLED=false
#                         others → PII_REDACTION_ENABLED=true PII_REDACTION_MODE=MODE
#   --hash-key KEY      PII_HASH_KEY=KEY (required when --pii hash)
#   --encrypt-key KEY   PII_ENCRYPT_KEY=KEY (required when --pii encrypt; any
#                         non-empty string -- gateway derives a 32-byte
#                         AES-256-GCM key via SHA-256 at boot)
#   --entities LIST     PII_ENABLED_ENTITIES=LIST (e.g. Email,SSN)
#   --hooks LIST        ENABLED_HOOKS=LIST (allowlist; empty = all)
#   --auth TOKEN        AUTH_TOKEN=TOKEN
#   --idle-timeout SEC  STREAM_IDLE_TIMEOUT_SEC=SEC (0 disables)
#
# .env loader (laptop-friendly persistence):
#   Loads the first match of:  ./.env  →  $GW_HOME/.env
#   Then chains the first match of:
#     ./overrides.env  →  $GW_HOME/overrides.env
#   Override either with --env-file PATH / --overrides-file PATH, or with
#   GW_ENV_FILE=PATH / GW_OVERRIDES_FILE=PATH.
#   The overrides file is loaded SECOND; same-key values win (two-file model).
#   CLI flags WIN over overrides; overrides WIN over .env; .env wins over
#   inherited shell env only for keys the file actually sets.
set -euo pipefail

# Resolve this script's own code dir, following symlinks. The one-liner
# installer exposes `gw` via a PATH symlink (e.g.
# ~/.local/bin/gw -> $GW_INSTALL_DIR/scripts/gw), so the wrapper may run
# from any cwd. Two anchors, resolved independently:
#   GW_INSTALL_DIR (code, replaceable on upgrade) — anchors bin/ + scripts/.
#   GW_HOME        (config, precious)              — anchors .env, logs,
#                   state, pid, sentinel. Default $HOME/.gw.
# NOT the caller's cwd — env overrides below still win. This also matches
# the legacy "cd into the extracted folder, run ./scripts/gw" flow, where
# GW_INSTALL_DIR == cwd.
_gw_source="${BASH_SOURCE[0]}"
while [[ -h "$_gw_source" ]]; do
    _gw_dir="$(cd -P "$(dirname "$_gw_source")" >/dev/null 2>&1 && pwd)"
    _gw_source="$(readlink "$_gw_source")"
    [[ "$_gw_source" != /* ]] && _gw_source="$_gw_dir/$_gw_source"
done
GW_SCRIPT_DIR="$(cd -P "$(dirname "$_gw_source")" >/dev/null 2>&1 && pwd)"
GW_INSTALL_DIR="${GW_INSTALL_DIR:-$(cd -P "$GW_SCRIPT_DIR/.." >/dev/null 2>&1 && pwd)}"
unset _gw_source _gw_dir

# GW_HOME anchors everything the operator's install actually owns. Separate
# from GW_INSTALL_DIR so binaries/scripts can be replaced on upgrade without
# touching .env / logs / state / pid.
GW_HOME="${GW_HOME:-$HOME/.gw}"

GW_BIN="${GW_BIN:-$GW_INSTALL_DIR/bin/gateway}"
# GW_STATE_DIR / GW_PID live under $GW_HOME (config home) rather than
# /tmp/ — some laptop setups (sandboxed shells, hardened tmp policies, network
# drives mapped to /tmp) make /tmp non-writable. The tray polls this same
# path for the gateway's running state, so wrapper and tray MUST agree.
GW_STATE_DIR="${GW_STATE_DIR:-$GW_HOME/state}"
GW_PID="${GW_PID:-${GW_STATE_DIR}/gateway.pid}"
# GW_LOG = the structured rotated log the gateway owns (via timberjack).
# GW_LOG_BOOT = a small sidecar that captures crash output + kiro-cli
# stderr + any pre-logger panic — rarely consulted, invaluable on incident.
GW_LOG="${GW_LOG:-$GW_HOME/logs/gateway.log}"
GW_LOG_BOOT="${GW_LOG_BOOT:-${GW_LOG%.log}-boot.log}"
GW_ADDR="${GW_ADDR:-http://127.0.0.1:18080}"

# Default .env search order. First hit wins; --env-file or GW_ENV_FILE overrides.
DEFAULT_ENV_PATHS=("./.env" "$GW_HOME/.env")

# Default overrides.env search order. Two-file model: .env is the
# template-copy (overwritten by upgrade-env); the overrides file is the operator's
# customization layer and is loaded SECOND so its keys win for any shared key.
# The .env-file and overrides-file flags are DECOUPLED: setting --env-file does
# NOT auto-resolve a sibling overrides file. Overrides resolution always walks
# the explicit precedence chain below.
DEFAULT_OVERRIDES_PATHS=("./overrides.env" "$GW_HOME/overrides.env")

# resolve_env_file returns the path of the .env file to source, or empty.
# Honors --env-file override (already parsed into $ENV_FILE_OVERRIDE) and
# GW_ENV_FILE before falling back to DEFAULT_ENV_PATHS.
resolve_env_file() {
    if [[ -n "${ENV_FILE_OVERRIDE:-}" ]]; then
        echo "$ENV_FILE_OVERRIDE"
        return 0
    fi
    if [[ -n "${GW_ENV_FILE:-}" ]]; then
        echo "$GW_ENV_FILE"
        return 0
    fi
    for path in "${DEFAULT_ENV_PATHS[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    # No match — explicit return 0 keeps `set -e` callers safe.
    return 0
}

# resolve_overrides_file returns the path of the overrides.env file
# the wrapper should load (after the primary .env), or empty when no overrides
# file is present anywhere on the precedence chain. Mirrors resolve_env_file's
# shape so the loader chaining inside load_config is symmetric.
#
# Precedence (highest first):
#   1. --overrides-file PATH   (parsed into OVERRIDES_FILE_OVERRIDE)
#   2. $GW_OVERRIDES_FILE    (env override)
#   3. DEFAULT_OVERRIDES_PATHS first hit (./, then $GW_HOME)
#
# Returns 0 on hit; returns 0 with empty stdout on miss (callers gate on
# `[[ -n "$overrides_file" ]]` so a clean miss is a no-op for load_config).
resolve_overrides_file() {
    if [[ -n "${OVERRIDES_FILE_OVERRIDE:-}" ]]; then
        echo "$OVERRIDES_FILE_OVERRIDE"
        return 0
    fi
    if [[ -n "${GW_OVERRIDES_FILE:-}" ]]; then
        echo "$GW_OVERRIDES_FILE"
        return 0
    fi
    for path in "${DEFAULT_OVERRIDES_PATHS[@]}"; do
        if [[ -f "$path" ]]; then
            echo "$path"
            return 0
        fi
    done
    return 0
}

# resolve_template_file returns the path of the .env.example template
# (the single source of truth for keys + defaults + per-key documentation).
# Precedence: --template PATH (TEMPLATE_FILE_OVERRIDE) > $GW_TEMPLATE_FILE >
# $GW_SCRIPT_DIR/.env.example (sibling to the wrapper). Echoes the
# resolved path; returns 1 if the resolved candidate does not exist on disk.
resolve_template_file() {
    local candidate=""
    if [[ -n "${TEMPLATE_FILE_OVERRIDE:-}" ]]; then
        candidate="$TEMPLATE_FILE_OVERRIDE"
    elif [[ -n "${GW_TEMPLATE_FILE:-}" ]]; then
        candidate="$GW_TEMPLATE_FILE"
    else
        candidate="$GW_SCRIPT_DIR/.env.example"
    fi
    if [[ ! -f "$candidate" ]]; then
        return 1
    fi
    echo "$candidate"
    return 0
}

# template_keys FILE — emit the ordered list of KEY names found in FILE
# (template or any env file), one key per line. Matches both uncommented
# `KEY=...` and commented `# KEY=...` lines, in file order. Prose-only
# comments (no '=' in the body) and blank lines are skipped. Same parser
# shape as extract_env_any.
template_keys() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local line key
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"
        [[ -z "$line" ]] && continue
        # Strip ONE leading '#' + optional whitespace so commented lines match.
        if [[ "$line" == \#* ]]; then
            line="${line#\#}"
            line="${line#"${line%%[![:space:]]*}"}"
        fi
        line="${line#export }"
        [[ "$line" == *=* ]] || continue
        key="${line%%=*}"
        # Defensive: a stray "= prose" line with no real key.
        [[ -n "$key" ]] || continue
        # Validate: keys must be FULLY shell-identifier-shaped end-to-end.
        # The `[[ =~ ]]` regex test catches prose like `# Syntax: KEY=value`
        # (would otherwise become the bogus key "Syntax: KEY"). bash 3.2
        # supports =~ since 3.0.
        if [[ ! "$key" =~ ^[A-Za-z_][A-Za-z0-9_]*$ ]]; then
            continue
        fi
        printf '%s\n' "$key"
    done < "$file"
}

# env_keys_present FILE — same as template_keys, but the name reads more
# naturally at the caller site for an arbitrary (non-template) env file.
# Kept as a thin alias so the upgrade-env diff calculation reads cleanly.
env_keys_present() {
    template_keys "$1"
}

# extract_default_value TEMPLATE KEY — given a template path, return the
# literal default value the template declares for KEY (whether the line is
# commented or not). Strips ONE layer of surrounding single or double quotes.
# Returns 0 on hit, 1 on miss. Used by migrate-to-overrides to decide which
# operator values differ from the template default and therefore need to be
# carried over.
extract_default_value() {
    extract_env_any "$1" "$2"
}

# config_error_sentinel_path returns the canonical sentinel path the
# tray polls each tick to surface dotenv parse failures as StateError
# (D-18-09 / REL-TRAY-08).
#
# WR-06: when $HOME is unset (degraded / sandboxed shell), refuse to
# fall back to /tmp. /tmp is world-writable and the sentinel content
# may contain a partial KEY=VALUE from the malformed dotenv line —
# including, in the worst case, fragments of AUTH_TOKEN or
# PII_HASH_KEY. Returning non-zero lets callers treat "no $HOME" as
# "no sentinel possible" and skip the write entirely; the WARN line
# on stderr is still emitted, so the operator's diagnostic path is
# preserved. A degraded shell missing $HOME is already unable to
# load .env from a sensible location, so the sentinel-skip
# is the safer of two bad options.
config_error_sentinel_path() {
    if [[ -z "${GW_HOME:-}" ]]; then
        return 1
    fi
    printf '%s/.config-error' "$GW_HOME"
}

# clear_config_error_sentinel removes the sentinel file. Called after
# every successful load_env_file so a one-shot parse failure does not
# stick once the operator fixes it. rm -f is idempotent — missing file
# is the happy path. When $HOME is unset, config_error_sentinel_path
# returns non-zero and there is nothing to clear.
clear_config_error_sentinel() {
    local sentinel
    sentinel="$(config_error_sentinel_path)" || return 0
    rm -f "$sentinel" 2>/dev/null || true
}

# write_config_error_sentinel writes $1 to the sentinel as a single
# line. Truncated to 200 bytes (head -c). Mode 0600 — sentinel may
# contain a partial KEY=VALUE from the malformed line (D-18-09 threat
# T-18-03-I). MkdirAll-equivalent for parent dir at 0750.
#
# WR-05: write via tmp + mv so the tray poller never observes a
# zero-byte intermediate. `printf > "$sentinel"` is open-then-truncate-
# then-write which has a window in which a poller tick reads the file
# as empty and falls through to the normal FSM state. Rename within the
# same filesystem is atomic on POSIX so the tray sees either the old
# content or the new content, never a torn read.
write_config_error_sentinel() {
    local msg="$1"
    local sentinel
    # WR-06: skip the sentinel entirely when $HOME is unset rather than
    # falling back to /tmp (world-writable; sentinel may carry partial
    # secret fragments). Caller stderr WARN still fires.
    sentinel="$(config_error_sentinel_path)" || return 0
    local sentinel_dir
    sentinel_dir="$(dirname "$sentinel")"
    mkdir -p "$sentinel_dir" 2>/dev/null || return 0
    chmod 0750 "$sentinel_dir" 2>/dev/null || true
    # First line only + 200-byte cap. tr replaces any \n with space
    # before head -c, so multi-line errors collapse to one line.
    # Write to a tmp sibling, chmod, then atomically rename into place.
    local tmp="${sentinel}.tmp.$$"
    printf '%s' "$msg" | tr '\n' ' ' | head -c 200 > "$tmp" 2>/dev/null || return 0
    chmod 0600 "$tmp" 2>/dev/null || true
    mv -f "$tmp" "$sentinel" 2>/dev/null || { rm -f "$tmp" 2>/dev/null; return 0; }
}

# load_env_file sources KEY=value lines from $1. Tolerates blank lines
# and # comments. Quoted values are honored. Does NOT execute arbitrary
# shell — we parse line-by-line and `export` each key explicitly so the
# .env file behaves as data, not code (no `$(...)` or backticks).
#
# REL-TRAY-08 (D-18-09): tracks malformed lines (no '=' after export
# strip) and writes the first failure to the sentinel at
# ${GW_HOME}/.config-error so the tray surfaces it as StateError.
# On a clean parse the sentinel is removed — failures should not stick
# across edits.
load_env_file() {
    local file="$1"
    [[ -f "$file" ]] || return 0
    local line key val lineno=0 first_error=""
    # SC2094 false positive: $(basename "$file") inside the body is read-only;
    # the < "$file" redirect is the read side only.
    # shellcheck disable=SC2094
    while IFS= read -r line || [[ -n "$line" ]]; do
        lineno=$((lineno + 1))
        # Strip leading whitespace.
        line="${line#"${line%%[![:space:]]*}"}"
        # Skip blanks and comments.
        [[ -z "$line" || "$line" == \#* ]] && continue
        # Strip optional leading "export ".
        line="${line#export }"
        # Must contain '='. Malformed lines that survive comment/blank
        # filtering are surfaced via the sentinel so the operator sees
        # them in the tray instead of getting a silent skip.
        if [[ "$line" != *=* ]]; then
            if [[ -z "$first_error" ]]; then
                first_error="$(basename "$file"):${lineno}: missing '=' (got: ${line:0:80})"
            fi
            continue
        fi
        key="${line%%=*}"
        val="${line#*=}"
        # Strip surrounding single or double quotes (one layer only).
        if [[ "$val" == \"*\" ]] || [[ "$val" == \'*\' ]]; then
            val="${val:1:${#val}-2}"
        fi
        export "$key=$val"
    done < "$file"
    if [[ -n "$first_error" ]]; then
        echo "config parse error: $first_error" >&2
        write_config_error_sentinel "$first_error"
    else
        clear_config_error_sentinel
    fi
}

# extract_env_any reads $1, finds the first KEY=value line for $2 (matching
# both uncommented `KEY=...` and commented `# KEY=...` forms), strips
# quotes, and echoes the value. Returns 0 on hit, 1 on miss. Same parser
# as load_env_file but does NOT export and does NOT skip commented lines —
# used by `init --force` to recover existing values from a prior install
# so AUTH_TOKEN / PII_HASH_KEY can be preserved across re-init.
extract_env_any() {
    local file="$1" key="$2"
    [[ -f "$file" ]] || return 1
    local line val
    while IFS= read -r line || [[ -n "$line" ]]; do
        line="${line#"${line%%[![:space:]]*}"}"
        [[ -z "$line" ]] && continue
        # Strip ONE leading '#' + optional whitespace so commented lines match.
        if [[ "$line" == \#* ]]; then
            line="${line#\#}"
            line="${line#"${line%%[![:space:]]*}"}"
        fi
        line="${line#export }"
        [[ "$line" == "$key="* ]] || continue
        val="${line#"$key="}"
        if [[ "$val" == \"*\" ]] || [[ "$val" == \'*\' ]]; then
            val="${val:1:${#val}-2}"
        fi
        printf '%s\n' "$val"
        return 0
    done < "$file"
    return 1
}

# set_env_line FILE KEY VALUE COMMENTED
# Rewrites the KEY= line in FILE (in-place). If COMMENTED is "1", the line
# is written as:  # KEY=VALUE. If COMMENTED is "0", written as: KEY=VALUE.
# Matches both commented and uncommented forms of the key, but only when
# KEY= is the sole content of the line (not embedded in prose comments).
# Uses awk for portability across BSD (macOS) and GNU sed environments.
set_env_line() {
    local file="$1" KEY="$2" VAL="$3" COMMENTED="$4"
    awk -v key="$KEY" -v val="$VAL" -v commented="$COMMENTED" '
      BEGIN { prefix = (commented == "1") ? "# " : "" }
      $0 ~ ("^[[:space:]]*#?[[:space:]]*" key "=[^[:space:]]*$") {
        print prefix key "=" val
        next
      }
      { print }
    ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
}

# set_overrides_line FILE KEY VALUE — write or update KEY=VALUE in the
# overrides.env file. Sibling to set_env_line, but with the
# overrides-file contract:
#   - Always writes UNCOMMENTED. The overrides file never carries commented
#     operator values; absence == "not customized".
#   - If FILE does not exist, create it with a small header that explains
#     the two-file model and the load-order win-condition, mode 0600.
#   - If KEY already exists, rewrite the line in place (awk → tmpfile → mv
#     pattern, same as set_env_line).
#   - Mode is always re-asserted to 0600 post-write — overrides hold secrets.
set_overrides_line() {
    local file="$1" KEY="$2" VAL="$3"
    if [[ ! -f "$file" ]]; then
        local ts
        ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        {
            printf '# Generated by '"'"'gw init'"'"' / '"'"'gw migrate-to-overrides'"'"' on %s\n' "$ts"
            printf '# Operator customizations + secrets. Loaded AFTER .env, so values here WIN.\n'
            printf '# Safe to hand-edit. Will NEVER be overwritten by '"'"'gw upgrade-env'"'"'.\n'
            printf '\n'
        } > "$file"
        chmod 600 "$file"
    fi
    # If the key already exists (commented or not), rewrite it in place.
    # Otherwise append at end. We use a grep+awk dance so the contract
    # ("always uncommented") holds whether or not a commented form exists.
    if grep -qE "^[[:space:]]*#?[[:space:]]*${KEY}=" "$file"; then
        awk -v key="$KEY" -v val="$VAL" '
          $0 ~ ("^[[:space:]]*#?[[:space:]]*" key "=") {
            print key "=" val
            next
          }
          { print }
        ' "$file" > "${file}.tmp" && mv "${file}.tmp" "$file"
    else
        printf '%s=%s\n' "$KEY" "$VAL" >> "$file"
    fi
    chmod 600 "$file"
}

# env_is_uncommented returns 0 if KEY= appears UNCOMMENTED in $1, else 1.
# Used by re-init to derive auth_enabled (uncommented AUTH_TOKEN) and
# chat_trace_enabled (uncommented CHAT_TRACE=true) state from the
# existing file without conflating "value present but disabled" with
# "value present and active".
env_is_uncommented() {
    local file="$1" key="$2"
    [[ -f "$file" ]] || return 1
    grep -qE "^[[:space:]]*(export[[:space:]]+)?${key}=" "$file"
}

# apply_cli_flags overrides exported vars with any --pii / --hash-key /
# etc. that came in on the command line. Called AFTER load_env_file so
# flags win.
apply_cli_flags() {
    if [[ -n "${FLAG_PII_MODE:-}" ]]; then
        if [[ "$FLAG_PII_MODE" == "off" ]]; then
            export PII_REDACTION_ENABLED="false"
        else
            export PII_REDACTION_ENABLED="true"
            export PII_REDACTION_MODE="$FLAG_PII_MODE"
        fi
    fi
    if [[ -n "${FLAG_HASH_KEY:-}" ]]; then export PII_HASH_KEY="$FLAG_HASH_KEY"; fi
    if [[ -n "${FLAG_ENCRYPT_KEY:-}" ]]; then export PII_ENCRYPT_KEY="$FLAG_ENCRYPT_KEY"; fi
    if [[ -n "${FLAG_ENTITIES:-}" ]]; then export PII_ENABLED_ENTITIES="$FLAG_ENTITIES"; fi
    if [[ -n "${FLAG_HOOKS:-}" ]];    then export ENABLED_HOOKS="$FLAG_HOOKS"; fi
    if [[ -n "${FLAG_AUTH:-}" ]];     then export AUTH_TOKEN="$FLAG_AUTH"; fi
    if [[ -n "${FLAG_IDLE_TIMEOUT:-}" ]]; then export STREAM_IDLE_TIMEOUT_SEC="$FLAG_IDLE_TIMEOUT"; fi
    if [[ "${FLAG_DEBUG:-0}" -eq 1 ]]; then export DEBUG="true"; fi
    if [[ "${FLAG_TRACE:-0}" -eq 1 ]]; then export DEBUG="true"; export CHAT_TRACE="true"; fi
    return 0
}

# parse_flags reads a remaining-args array (positional after the
# subcommand) and populates the FLAG_* globals + ENV_FILE_OVERRIDE.
# `--show-secrets` is only meaningful for the `env` subcommand but is
# parsed uniformly so callers can preview "what would happen with
# secrets visible." Anything not recognised → `unknown flag` exit.
parse_flags() {
    # shellcheck disable=SC2034  # FLAG_OVERRIDES_DEST is consumed by migrate-to-overrides (Task 3 in 260531-tl1).
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --pii)           FLAG_PII_MODE="$2"; shift 2 ;;
            --pii=*)         FLAG_PII_MODE="${1#*=}"; shift ;;
            --hash-key)      FLAG_HASH_KEY="$2"; shift 2 ;;
            --hash-key=*)    FLAG_HASH_KEY="${1#*=}"; shift ;;
            --encrypt-key)   FLAG_ENCRYPT_KEY="$2"; shift 2 ;;
            --encrypt-key=*) FLAG_ENCRYPT_KEY="${1#*=}"; shift ;;
            --idle-timeout)  FLAG_IDLE_TIMEOUT="$2"; shift 2 ;;
            --idle-timeout=*) FLAG_IDLE_TIMEOUT="${1#*=}"; shift ;;
            --entities)      FLAG_ENTITIES="$2"; shift 2 ;;
            --entities=*)    FLAG_ENTITIES="${1#*=}"; shift ;;
            --hooks)         FLAG_HOOKS="$2"; shift 2 ;;
            --hooks=*)       FLAG_HOOKS="${1#*=}"; shift ;;
            --auth)          FLAG_AUTH="$2"; shift 2 ;;
            --auth=*)        FLAG_AUTH="${1#*=}"; shift ;;
            --env-file)      ENV_FILE_OVERRIDE="$2"; shift 2 ;;
            --env-file=*)    ENV_FILE_OVERRIDE="${1#*=}"; shift ;;
            --overrides-file)     OVERRIDES_FILE_OVERRIDE="$2"; shift 2 ;;
            --overrides-file=*)   OVERRIDES_FILE_OVERRIDE="${1#*=}"; shift ;;
            --template)      TEMPLATE_FILE_OVERRIDE="$2"; shift 2 ;;
            --template=*)    TEMPLATE_FILE_OVERRIDE="${1#*=}"; shift ;;
            --dest)          FLAG_DEST="$2"; shift 2 ;;
            --dest=*)        FLAG_DEST="${1#*=}"; shift ;;
            --overrides-dest)   FLAG_OVERRIDES_DEST="$2"; shift 2 ;;
            --overrides-dest=*) FLAG_OVERRIDES_DEST="${1#*=}"; shift ;;
            --dry-run)       FLAG_DRY_RUN=1; shift ;;
            --yes)           FLAG_YES=1; shift ;;
            --show-secrets)  FLAG_SHOW_SECRETS=1; shift ;;
            --debug)         FLAG_DEBUG=1; shift ;;
            --trace)         FLAG_TRACE=1; shift ;;
            *)               echo "unknown flag: $1" >&2; exit 1 ;;
        esac
    done
}

# _deprecation_warn_emitted sentinel for detect_single_file_model — keeps
# the deprecation WARN line from repeating inside a single wrapper
# invocation. Mirrors the _reap_kiro_done pattern.
_deprecation_warn_emitted=""

# detect_single_file_model — emit a one-line deprecation WARN when the
# operator is running on the legacy single-file install model (no
# overrides.env, .env carries uncommented operator
# values). The WARN goes to stderr to keep structured-log capture clean.
#
# Single-file model is detected when ALL of:
#   1. No overrides.env on any of the resolved overrides paths.
#   2. A .env (the single-file form) exists.
#   3. At least one of AUTH_TOKEN, PII_HASH_KEY, HTTP_ADDR is uncommented
#      with a non-placeholder value, OR KIRO_CMD is uncommented and
#      non-empty. These are the keys init writes uncommented and that
#      meaningfully indicate operator customization (vs. a virgin
#      template copy).
#
# Explicitly NOT an error and NOT auto-migrating — operator decides when
# to run `gw migrate-to-overrides`. Single-file support is scheduled
# for removal in v1.7.
detect_single_file_model() {
    [[ -n "$_deprecation_warn_emitted" ]] && return 0
    local env_file overrides_file
    env_file="$(resolve_env_file)"
    overrides_file="$(resolve_overrides_file)"

    # Conditions 1 + 2 — clean misses end the check.
    [[ -n "$env_file" && -f "$env_file" ]] || return 0
    [[ -z "$overrides_file" || ! -f "$overrides_file" ]] || return 0

    # Condition 3 — at least one operator-set tell-tale key.
    local has_operator_value=0
    local k val
    for k in AUTH_TOKEN PII_HASH_KEY HTTP_ADDR; do
        if env_is_uncommented "$env_file" "$k"; then
            val="$(extract_env_any "$env_file" "$k" 2>/dev/null || true)"
            case "$val" in
                # Skip the template's placeholder values; they don't count
                # as "operator-set" for the deprecation heuristic.
                ""|"replace-me"|"replace-with-32-byte-secret-key-here") ;;
                *) has_operator_value=1; break ;;
            esac
        fi
    done
    if [[ "$has_operator_value" -ne 1 ]]; then
        if env_is_uncommented "$env_file" KIRO_CMD; then
            val="$(extract_env_any "$env_file" KIRO_CMD 2>/dev/null || true)"
            [[ -n "$val" ]] && has_operator_value=1
        fi
    fi
    [[ "$has_operator_value" -eq 1 ]] || return 0

    _deprecation_warn_emitted=1
    echo "gw: legacy single-file .env model detected — run \`gw migrate-to-overrides\` to split secrets/overrides into overrides.env. Single-file support will be removed in v1.7." >&2
}

# load_config is the standard pre-launch hook: resolve .env → source it,
# resolve overrides → source it (last-write-wins, so overrides values win),
# then apply CLI flag overrides. Idempotent; safe to call from start /
# restart / run / env.
#
# Two-file model (locked in 260531-tl1 CONTEXT.md Decision 1):
#   1. .env (generated, byte-for-byte template copy, never edited by
#      operator). load_env_file's `export "$key=$val"` is intentionally
#      last-write-wins, so any commented line in this file is a no-op.
#   2. overrides.env (operator-owned, contains only the keys the
#      operator wants to set). Loaded SECOND so its KEY= line clobbers the
#      same KEY= from the generated file (the override mechanism).
load_config() {
    local env_file overrides_file
    env_file="$(resolve_env_file)"
    if [[ -n "$env_file" ]]; then
        load_env_file "$env_file"
        echo "loaded env file: $env_file" >&2
        # Surface the resolved path to the gateway so it can log at INFO
        # which file the wrapper actually used. The binary reads this from
        # os.Getenv("GW_ENV_FILE_LOADED") at startup.
        export GW_ENV_FILE_LOADED="$env_file"
    fi
    overrides_file="$(resolve_overrides_file)"
    if [[ -n "$overrides_file" && -f "$overrides_file" ]]; then
        load_env_file "$overrides_file"
        echo "loaded overrides:  $overrides_file" >&2
        # Sibling of GW_ENV_FILE_LOADED — gives the gateway both files for
        # /api/version + observability without re-walking the resolver chain.
        export GW_OVERRIDES_FILE_LOADED="$overrides_file"
    fi
    # One-shot deprecation warning when the legacy single-file model is in use.
    # The sentinel inside the function keeps the line from repeating across
    # multiple load_config calls inside one wrapper invocation.
    detect_single_file_model
    apply_cli_flags
}

# preflight_kiro resolves KIRO_CMD before the gateway launches:
#   1. If KIRO_CMD is unset → auto-detect `kiro-cli` on PATH and silently
#      set KIRO_CMD. Surfaces a brief "auto-detected" line so the
#      operator sees what just happened without having to inspect
#      /api/version or the log.
#   2. If KIRO_CMD is set but doesn't resolve → warn (don't abort).
#   3. If KIRO_CMD is set and resolves → silent (happy path).
#
# Degraded boot (no kiro-cli found) is non-fatal because /health,
# /health/hooks, and /health/pool all work without it — operators may
# genuinely want a diagnostic-only run. Returns 0 always.
preflight_kiro() {
    local kiro="${KIRO_CMD:-}"
    if [[ -z "$kiro" ]]; then
        # Auto-detect before warning. command -v handles both absolute
        # paths (a hash-table lookup miss) and PATH resolution.
        local found
        found="$(command -v kiro-cli 2>/dev/null || true)"
        if [[ -n "$found" ]]; then
            export KIRO_CMD="$found"
            echo "  ✓  KIRO_CMD auto-detected: $found"
            return 0
        fi
        echo "  ⚠  KIRO_CMD is unset and 'kiro-cli' is not on PATH — gateway will boot but chat requests will return 503." >&2
        echo "     Install kiro-cli OR set KIRO_CMD in your .env (or shell)." >&2
        return 0
    fi
    # KIRO_CMD is set — validate it resolves to an executable. Try as
    # absolute path first (covers KIRO_CMD=/abs/path/to/kiro-cli); fall
    # back to PATH resolution (covers KIRO_CMD=kiro-cli).
    if [[ -x "$kiro" ]] || command -v "$kiro" >/dev/null 2>&1; then
        return 0
    fi
    echo "  ⚠  KIRO_CMD=\"$kiro\" does not resolve to an executable on PATH or as an absolute path." >&2
    echo "     Gateway will boot but chat requests will return 503 until this is fixed." >&2
    return 0
}

# wait_until_ready polls ${GW_ADDR}/health up to $1 seconds (default 5).
# Returns 0 on first 2xx; 1 on timeout or non-2xx after all retries.
# Silent on success; on failure tails the last 20 lines of the boot
# sidecar so the operator sees why the gateway never came up.
wait_until_ready() {
    local timeout_s="${1:-5}"
    if ! command -v curl >/dev/null 2>&1; then
        # No curl → skip the probe entirely. Operator can `status` manually.
        return 0
    fi
    local deadline=$(( $(date +%s) + timeout_s ))
    while (( $(date +%s) < deadline )); do
        if curl -sf -m 1 "${GW_ADDR}/health" >/dev/null 2>&1; then
            return 0
        fi
        # Also bail early if the binary already exited (PID file's pid is dead).
        if [[ -f "$GW_PID" ]]; then
            local p; p=$(cat "$GW_PID")
            if ! kill -0 "$p" 2>/dev/null; then
                break
            fi
        fi
        sleep 0.25
    done
    return 1
}

start() {
    if [[ -f "$GW_PID" ]]; then
        local pid
        pid=$(cat "$GW_PID")
        if kill -0 "$pid" 2>/dev/null; then
            echo "gateway is already running (PID $pid)" >&2
            exit 1
        fi
        rm -f "$GW_PID"
    fi
    load_config
    # Ensure the log + state directories exist before launch. Supports
    # both the default $GW_HOME/{logs,state}/ config-home layout and any
    # custom GW_LOG / GW_PID paths the operator set.
    local log_dir state_dir
    log_dir="$(dirname "$GW_LOG")"
    if [[ -n "$log_dir" && "$log_dir" != "." ]]; then
        mkdir -p "$log_dir"
    fi
    state_dir="$(dirname "$GW_PID")"
    if [[ -n "$state_dir" && "$state_dir" != "." ]]; then
        mkdir -p "$state_dir"
    fi
    # Gateway env vars are inherited from the current environment
    # automatically — no explicit forwarding needed. Documented set:
    #   KIRO_CMD, KIRO_ARGS, KIRO_CWD           — kiro-cli subprocess wiring
    #   DEBUG, HTTP_ADDR, PING_INTERVAL         — runtime knobs
    #   AUTH_TOKEN, ALLOWED_IPS                 — auth + IP allowlist (Phase 2)
    #   AUTH_TRUST_XFF                          — opt-in XFF trust (Codex H-7)
    #   POOL_SIZE                               — warm-pool size (Phase 2)
    #   OLLAMA_PATH_PREFIX, OPENAI_PATH_PREFIX  — route prefixes
    #   ENABLED_HOOKS, PII_REDACTION_ENABLED,   — Phase 8 hook chain knobs
    #   PII_ENABLED_ENTITIES, PII_REDACTION_MODE,
    #   PII_HASH_KEY, PII_ENCRYPT_KEY, PII_ENTITY_ACTIONS
    #   LOG_FILE                                — daily-rotated log path (timberjack)
    # LOG_FILE points the gateway's structured slog output at the rotated
    # log. nohup's redirect then captures only stderr / pre-logger output /
    # crash trails into the small boot sidecar.
    export LOG_FILE="$GW_LOG"
    preflight_kiro
    nohup "$GW_BIN" >> "$GW_LOG_BOOT" 2>&1 &
    echo $! > "$GW_PID"
    echo "gateway starting (PID $(cat "$GW_PID"))…"
    echo "  log:      $GW_LOG (rotated daily, 7d retention)"
    echo "  boot/err: $GW_LOG_BOOT"
    # Block briefly until /health returns 2xx so the operator sees the
    # actual ready/failed verdict instead of a phantom "running" PID
    # they only discover is dead on the next subcommand.
    #
    # The 10s budget covers a normal boot (sub-second on a working kiro)
    # and most warmup paths. A broken KIRO_CMD takes the gateway's
    # warmupDeadline (30s) to fail; the readiness probe will time out
    # before that and surface the partial structured-log tail so the
    # operator sees what's wrong without waiting the full 30s.
    if wait_until_ready 10; then
        echo "  ready:    ${GW_ADDR}/health"
    else
        echo "  ❌  gateway did NOT become ready within 10s." >&2
        # Prefer the structured log (where slog calls go when LOG_FILE
        # is set) and fall back to the boot sidecar (where pre-logger
        # / Go runtime / kiro-cli stderr lands).
        local source_log=""
        if [[ -s "$GW_LOG" ]]; then
            source_log="$GW_LOG"
        elif [[ -s "$GW_LOG_BOOT" ]]; then
            source_log="$GW_LOG_BOOT"
        fi
        if [[ -n "$source_log" ]]; then
            echo "     Last 20 lines of $source_log:" >&2
            tail -n 20 "$source_log" | sed 's/^/       /' >&2
        else
            echo "     (both log files are empty — likely a hung warmup; check KIRO_CMD)" >&2
        fi
        exit 1
    fi
}

# _wait_for_exit PID — block up to ~10s for PID to leave the process table.
# Eliminates the restart race (Codex MEDIUM fix).
_wait_for_exit() {
    local p="$1" i=0
    while kill -0 "$p" 2>/dev/null && [[ "$i" -lt 100 ]]; do
        sleep 0.1
        i=$((i + 1))
    done
}

# gateway_pids — print PIDs of the running gateway *binary* (one per line).
# Prefers pgrep; degrades to `ps | grep` where pgrep is absent. Matches the
# full binary path (e.g. $GW_INSTALL_DIR/bin/gateway), not the bare name, so
# it can't accidentally match a log tail (logs/gateway.log) or this wrapper
# (gw). The wrapper always execs the binary by absolute path, so a running
# instance's argv carries it.
gateway_pids() {
    if command -v pgrep >/dev/null 2>&1; then
        pgrep -f "$GW_BIN" 2>/dev/null
    else
        # `grep -v grep` drops the matcher's own line; the ps header has no
        # match so it falls out naturally. -A/-o pid,args is BSD+GNU portable;
        # -F keeps the path a literal (its dots aren't treated as regex).
        # shellcheck disable=SC2009  # pgrep is the preferred path above; this is the fallback
        ps -A -o pid,args 2>/dev/null \
            | grep -F "$GW_BIN" \
            | grep -v grep \
            | awk '{print $1}'
    fi
}

# _reap_kiro_done is the one-shot guard so reap_kiro_orphans() only runs
# its env-load + ps-scan once per `gw` invocation. stop() calls into
# stop_by_name() on stale-PID fallback, and both invoke reap_kiro_orphans
# at their tail — without this guard the operator would see the scan
# attempted twice on the same invocation.
_reap_kiro_done=""

# reap_kiro_orphans — 260531-ra6 RA6-03. Belt-and-suspenders cleanup for
# hard-crash paths (segfault, OOM, SIGKILL of the gateway) where the
# Task 2 process-group cascade cannot help. Called from the tail of
# stop() and stop_by_name(); the _reap_kiro_done sentinel keeps it
# idempotent within a single wrapper invocation.
#
# Safety: matches strictly against the resolved $KIRO_CMD absolute path
# (never the bare "kiro" or "kiro-cli" basename), so a kiro-cli the
# operator runs OUTSIDE the gateway is untouched. Also refuses to
# signal our own pid or any ancestor pid (best-effort: $$ + $PPID).
reap_kiro_orphans() {
    [[ -n "$_reap_kiro_done" ]] && return 0
    _reap_kiro_done=1

    # stop() does not invoke load_config (start() does); load .env locally
    # so $KIRO_CMD is in scope without changing stop()'s startup behaviour.
    local env_file
    env_file="$(resolve_env_file)"
    [[ -n "$env_file" ]] && load_env_file "$env_file"

    # No KIRO_CMD configured ⇒ nothing to reap. Silent return.
    [[ -n "${KIRO_CMD:-}" ]] || return 0

    # Resolve to absolute path so the ps command-field match is exact.
    # Operators commonly set KIRO_CMD to a bare name ("kiro-cli") and rely
    # on PATH resolution — the running subprocess's argv[0] will be the
    # absolute path the OS resolved. `command -v` resolves bare names;
    # for an already-absolute KIRO_CMD it echoes the same value.
    local kiro_path
    kiro_path="$(command -v "$KIRO_CMD" 2>/dev/null || true)"
    [[ -n "$kiro_path" ]] || kiro_path="$KIRO_CMD"

    # 2s grace for any SIGTERM that already went out (Task 2 pgrp cascade,
    # the gateway's own shutdown, etc.) to deliver and exit children
    # cleanly before we start swinging signals around.
    sleep 2

    # Scan ps for processes whose command field EXACTLY equals $kiro_path.
    # `ps -eo pid,command` is supported on both BSD (macOS) and GNU (Linux);
    # awk's $2 == cmd matches the command field exactly (basename or full
    # path, whichever the OS recorded). NEVER substring-match — we MUST
    # NOT kill kiro-cli processes the operator is running outside the
    # gateway (T-ra6-01).
    local pids self ancestors fp
    pids="$(ps -eo pid,command 2>/dev/null \
        | awk -v cmd="$kiro_path" '$2 == cmd {print $1}')"

    [[ -n "$pids" ]] || return 0

    # Sanity: never signal our own shell pid or its parent. Trim and
    # filter. (We don't walk the full ancestor chain — $$ and $PPID
    # cover the realistic risk; a kiro-cli pid colliding with a deeper
    # ancestor would require KIRO_CMD itself to be the parent shell,
    # which is nonsensical.)
    self="$$"
    ancestors=" $self $PPID "
    local filtered=""
    for fp in $pids; do
        if [[ " $ancestors " == *" $fp "* ]]; then
            continue
        fi
        filtered="${filtered:+$filtered }$fp"
    done
    pids="$filtered"
    [[ -n "$pids" ]] || return 0

    echo "gw: reaping stray kiro-cli orphans: $pids"
    for fp in $pids; do
        kill "$fp" 2>/dev/null || true
    done
    sleep 2

    # Re-scan; SIGKILL any survivors.
    local survivors=""
    survivors="$(ps -eo pid,command 2>/dev/null \
        | awk -v cmd="$kiro_path" '$2 == cmd {print $1}')"
    if [[ -n "$survivors" ]]; then
        local sf
        for sf in $survivors; do
            if [[ " $ancestors " == *" $sf "* ]]; then
                continue
            fi
            kill -KILL "$sf" 2>/dev/null || true
        done
    fi
    echo "gw: kiro-cli orphans reaped"
}

# stop_by_name REASON — fallback when the PID file can't drive the stop (older
# wrapper wrote it elsewhere, or the gateway was launched in the foreground via
# 'run'). Returns 0 if it signalled at least one process, 1 if none were found.
stop_by_name() {
    local pids fp
    pids="$(gateway_pids)"
    [[ -n "$pids" ]] || return 1
    echo "gateway: $1; stopping running process(es) by name"
    for fp in $pids; do
        kill "$fp" 2>/dev/null || true
        _wait_for_exit "$fp"
    done
    echo "gateway stopped"
    reap_kiro_orphans
    return 0
}

# stop returns 0 when the gateway is (now) stopped, 1 when nothing was running.
# It uses `return` rather than `exit` so restart() can proceed to start().
stop() {
    if [[ -f "$GW_PID" ]]; then
        local pid
        pid=$(cat "$GW_PID")
        if kill -0 "$pid" 2>/dev/null; then
            actual_comm=$(ps -p "$pid" -o comm= 2>/dev/null || true)
            if [[ "$actual_comm" != *gateway* ]]; then
                echo "gw: stop: PID $pid is alive but comm='$actual_comm' — stale PID file" >&2
                rm -f "$GW_PID"
                stop_by_name "stale recycled PID" && return 0
                return 0
            fi
            kill "$pid"
            _wait_for_exit "$pid"
            rm -f "$GW_PID"
            echo "gateway stopped"
            reap_kiro_orphans
            return 0
        fi
        # Stale file: a live instance may still be running without it.
        rm -f "$GW_PID"
        stop_by_name "stale PID" && return 0
        echo "gateway: stopped (stale PID)"
        reap_kiro_orphans
        return 0
    fi
    # No PID file at all — try to match the running binary by name.
    stop_by_name "no PID file" && return 0
    echo "gateway is not running (no PID file)" >&2
    return 1
}

status() {
    if [[ ! -f "$GW_PID" ]]; then
        echo "gateway: stopped"
        exit 1
    fi
    local pid
    pid=$(cat "$GW_PID")
    if ! kill -0 "$pid" 2>/dev/null; then
        echo "gateway: stopped (stale PID)"
        exit 1
    fi
    echo "gateway: running (PID $pid)"
    command -v curl >/dev/null 2>&1 || return 0
    local body
    body="$(curl -sf "${GW_ADDR}/health" 2>/dev/null || true)"
    [[ -n "$body" ]] || { echo "  (health check unreachable at ${GW_ADDR}/health)"; return 0; }
    # Parse the flat /health JSON with sed — no jq/python dependency. Keys are
    # unique across the document (D-12 locked shape), so a greedy match finds
    # the single occurrence of each. Embeddings intentionally omitted.
    local status version uptime size alive busy active
    status="$(printf '%s' "$body"  | sed -n 's/.*"status"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
    version="$(printf '%s' "$body" | sed -n 's/.*"version"[[:space:]]*:[[:space:]]*"\([^"]*\)".*/\1/p')"
    uptime="$(printf '%s' "$body"  | sed -n 's/.*"uptime_seconds"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
    size="$(printf '%s' "$body"    | sed -n 's/.*"size"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
    alive="$(printf '%s' "$body"   | sed -n 's/.*"alive"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
    busy="$(printf '%s' "$body"    | sed -n 's/.*"busy"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
    active="$(printf '%s' "$body"  | sed -n 's/.*"active"[[:space:]]*:[[:space:]]*\([0-9]*\).*/\1/p')"
    [[ -n "$status" ]]  && echo "  status:   $status"
    [[ -n "$version" ]] && echo "  version:  $version"
    [[ -n "$uptime" ]]  && echo "  uptime:   $(humanize_uptime "$uptime")"
    [[ -n "$size$alive$busy" ]] && echo "  pool:     size=${size:-0}, alive=${alive:-0}, busy=${busy:-0}"
    [[ -n "$active" ]]  && echo "  sessions: active=$active"

    # Feature-flag enablement comes from the admin snapshot, NOT /health
    # (which is D-12 byte-shape locked). The admin endpoint is auth-exempt,
    # so no token is needed. Best-effort like the health probe above: if it
    # is unreachable we skip the lines silently rather than failing status.
    local snap dbg trace
    snap="$(curl -sf "${GW_ADDR}/admin/api/snapshot" 2>/dev/null || true)"
    [[ -n "$snap" ]] || return 0
    # JSON booleans have no surrounding quotes — capture the bare word. Use a
    # char class, NOT \(true\|false\): BSD sed (macOS) does not support \|
    # alternation in BRE and would silently match nothing. The downstream
    # == "true" test maps anything else (incl. an empty parse) to "off".
    dbg="$(printf '%s' "$snap"   | sed -n 's/.*"debug"[[:space:]]*:[[:space:]]*\([a-z][a-z]*\).*/\1/p')"
    trace="$(printf '%s' "$snap" | sed -n 's/.*"chat_trace"[[:space:]]*:[[:space:]]*\([a-z][a-z]*\).*/\1/p')"
    [[ -n "$dbg" ]]   && echo "  debug:      $([[ "$dbg" == "true" ]] && echo on || echo off)"
    [[ -n "$trace" ]] && echo "  chat-trace: $([[ "$trace" == "true" ]] && echo on || echo off)"
}

# humanize_uptime turns whole seconds into a compact Hh Mm Ss form.
humanize_uptime() {
    local s="$1" h m sec
    h=$((s / 3600)); m=$(((s % 3600) / 60)); sec=$((s % 60))
    if [[ "$h" -gt 0 ]];   then echo "${h}h ${m}m ${sec}s"
    elif [[ "$m" -gt 0 ]]; then echo "${m}m ${sec}s"
    else echo "${sec}s"; fi
}

restart() {
    stop || true   # a not-running gateway is fine; restart should still start it
    start
}

logs() {
    local follow="${1:-}"
    if [[ "$follow" == "-f" ]]; then
        tail -f "$GW_LOG"
    else
        tail -n 50 "$GW_LOG"
    fi
}

run() {
    load_config
    # Foreground execution — inherits all env vars from the calling shell.
    exec "$GW_BIN"
}

# show_version delegates to the binary's --version handler so the wrapper
# and the binary cannot disagree. The version string is the same one
# baked into the binary at build time via the Makefile's `-X` ldflag.
show_version() {
    if [[ ! -x "$GW_BIN" ]]; then
        echo "Error: $GW_BIN not found or not executable." >&2
        exit 1
    fi
    "$GW_BIN" --version
}

# gen_random_hex N → 2*N hex characters from a CSPRNG. Prefers openssl
# (universally present on macOS, package-available on Linux); falls back
# to /dev/urandom + od for minimalist environments.
gen_random_hex() {
    local nbytes="${1:-32}"
    if command -v openssl >/dev/null 2>&1; then
        openssl rand -hex "$nbytes"
    elif [[ -r /dev/urandom ]]; then
        head -c "$nbytes" /dev/urandom | od -An -vtx1 | tr -d ' \n'
    else
        echo "ERROR: no CSPRNG available (need openssl or /dev/urandom)" >&2
        return 1
    fi
}

# upgrade_env_cmd regenerates the generated `.env` from the
# `.env.example` template, reporting which keys would be added /
# orphaned / left unchanged. Operator customizations live in the
# `overrides.env` file (loaded last by load_config) and are NEVER
# touched by this command — the whole point of the two-file model.
#
# Subcommand contract (locked in 260531-tl1 CONTEXT.md Decision 3):
#   - --dry-run   print the diff (added / orphaned / unchanged), exit 0,
#                 leave disk unchanged.
#   - default     prompt to overwrite (unless --yes), then regenerate the
#                 dest file from the template and append the orphan log.
#   - --yes       skip the confirmation prompt (CI-friendly).
#   - --template  override template path (handy for unreleased templates).
#   - --dest      override the resolved `.env` path.
upgrade_env_cmd() {
    parse_flags "$@"
    local template dest
    if ! template="$(resolve_template_file)"; then
        echo "ERROR: upgrade-env template not found." >&2
        echo "       Looked at: ${TEMPLATE_FILE_OVERRIDE:-${GW_TEMPLATE_FILE:-$GW_SCRIPT_DIR/.env.example}}" >&2
        exit 1
    fi
    dest="${FLAG_DEST:-}"
    if [[ -z "$dest" ]]; then
        dest="$(resolve_env_file)"
    fi
    # Cold-init fallback: if nothing exists yet, default to project-local.
    [[ -z "$dest" ]] && dest="${DEFAULT_ENV_PATHS[0]}"

    # Build sorted line-lists for the set-diff. comm requires sorted inputs.
    local t_sorted c_sorted
    t_sorted="$(template_keys "$template" | sort -u)"
    if [[ -f "$dest" ]]; then
        c_sorted="$(env_keys_present "$dest" | sort -u)"
    else
        c_sorted=""
    fi

    # `comm -23 A B` = lines unique to A (in template, missing from dest) = added.
    # `comm -13 A B` = lines unique to B (in dest, missing from template) = orphaned.
    # `comm -12 A B` = lines in both = unchanged.
    # Process substitution is bash-3.2 safe (it's a bash builtin, not a 4.x feature).
    local added orphaned unchanged
    added="$(comm -23 <(printf '%s\n' "$t_sorted") <(printf '%s\n' "$c_sorted") | grep -v '^$' || true)"
    orphaned="$(comm -13 <(printf '%s\n' "$t_sorted") <(printf '%s\n' "$c_sorted") | grep -v '^$' || true)"
    unchanged="$(comm -12 <(printf '%s\n' "$t_sorted") <(printf '%s\n' "$c_sorted") | grep -v '^$' || true)"

    local n_added n_orphaned n_unchanged
    n_added="$(printf '%s\n' "$added"   | grep -c . || true)"
    n_orphaned="$(printf '%s\n' "$orphaned" | grep -c . || true)"
    n_unchanged="$(printf '%s\n' "$unchanged" | grep -c . || true)"

    # "Up to date" is byte-identity with the template, NOT key-set equality.
    # upgrade-env regenerates .env as a byte-for-byte copy, so a value/comment
    # change (same keys) still updates the file — reporting "nothing to change"
    # off the key diff alone would be misleading.
    local identical=0
    if [[ -f "$dest" ]] && cmp -s "$template" "$dest"; then identical=1; fi

    local mode
    if [[ "${FLAG_DRY_RUN:-0}" == "1" ]]; then mode="dry-run — nothing will be written"; else mode="applying"; fi
    echo "gw upgrade-env ($mode)"
    echo "  template:  $template"
    echo "  your .env: $dest"
    echo ""
    if [[ "$identical" == "1" ]]; then
        echo "  Your .env already matches the template — nothing to change ($n_unchanged keys)."
    else
        if [[ "$n_added" -gt 0 ]]; then
            # One key per line so a long list is readable ($added is already
            # sorted+unique from comm above).
            echo "  + $n_added new key(s) to ADD to your .env:"
            printf '%s\n' "$added" | sed 's/^/      /'
        else
            echo "  + 0 new keys to add"
        fi
        if [[ "$n_orphaned" -gt 0 ]]; then
            echo "  - $n_orphaned key(s) in your .env are no longer in the template (will be REMOVED; old values saved to the upgrade log first):"
            printf '%s\n' "$orphaned" | sed 's/^/      /'
        else
            echo "  - 0 keys to remove"
        fi
        echo "  = $n_unchanged key(s) unchanged"
        if [[ "$n_added" -eq 0 && "$n_orphaned" -eq 0 ]]; then
            echo "  (no keys added or removed, but the template's default values or comments changed — applying refreshes .env to match)"
        fi
    fi
    echo ""
    echo "  Note: your customizations in overrides.env are never touched by upgrade-env."

    if [[ "${FLAG_DRY_RUN:-0}" == "1" ]]; then
        echo "  To apply, run:  gw upgrade-env    (without --dry-run)"
        return 0
    fi

    # Confirm before overwriting (skip when --yes). A non-existent dest is
    # effectively a cold init; no confirm needed because nothing is being
    # destroyed.
    if [[ "${FLAG_YES:-0}" != "1" && -f "$dest" ]]; then
        local reply
        read -r -p "Overwrite $dest with current template? [y/N]: " reply
        case "$reply" in
            [Yy]|[Yy][Ee][Ss]) ;;
            *) echo "cancelled" >&2; exit 1 ;;
        esac
    fi

    # Write the orphan log BEFORE overwriting. If a SIGKILL lands between the
    # log write and the cp, the operator still has their old file AND a log
    # of what was about to be lost. The default location is per-user (~);
    # GW_UPGRADE_LOG overrides for CI installs without $HOME.
    local upgrade_log
    if [[ -n "${GW_UPGRADE_LOG:-}" ]]; then
        upgrade_log="$GW_UPGRADE_LOG"
    elif [[ -n "${HOME:-}" ]]; then
        upgrade_log="$GW_HOME/upgrade.log"
    else
        # Per Risk #8 in PLAN.md: never silently swallow the orphan log.
        upgrade_log="./upgrade.log"
    fi
    if [[ "$n_orphaned" -gt 0 ]]; then
        local ts k v
        ts="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
        {
            echo "# $ts upgrade-env removed orphaned keys from $dest"
            for k in $orphaned; do
                v="$(extract_env_any "$dest" "$k" 2>/dev/null || echo '<unset>')"
                echo "$k=$v"
            done
            echo "# ---"
        } >> "$upgrade_log"
        echo "  orphan values logged to: $upgrade_log"
    fi

    # Regenerate dest as a literal byte-for-byte copy of the template. The
    # generated file's contract under the new model is "pure template copy";
    # the operator's customizations live in overrides.env (which
    # we never touch here).
    cp "$template" "$dest"
    chmod 644 "$dest"
    echo "✓ wrote $dest"
}

# migrate_to_overrides_cmd performs the one-time migration from the legacy
# single-file model to the two-file (env + overrides) model. Extracts every
# uncommented key from the current `.env` whose value differs from
# the template default, writes those to `overrides.env`, backs up
# the original `.env`, and regenerates the env file from the
# template (pure copy under the new contract).
#
# Idempotency (locked in 260531-tl1 CONTEXT.md Decision 4): re-running on an
# already-migrated install is a no-op. The check: overrides file exists AND
# the current .env is byte-identical to the template (i.e. nothing
# to migrate).
#
# Secrets (AUTH_TOKEN, PII_HASH_KEY) are ALWAYS carried across when
# uncommented in the source file, even if their value happens to equal the
# template placeholder — they're load-bearing for client auth + hash-mode
# correlation, never "default".
migrate_to_overrides_cmd() {
    parse_flags "$@"
    local template dest overrides_dest
    if ! template="$(resolve_template_file)"; then
        echo "ERROR: migrate-to-overrides template not found." >&2
        echo "       Looked at: ${TEMPLATE_FILE_OVERRIDE:-${GW_TEMPLATE_FILE:-$GW_SCRIPT_DIR/.env.example}}" >&2
        exit 1
    fi
    dest="${FLAG_DEST:-}"
    if [[ -z "$dest" ]]; then
        dest="$(resolve_env_file)"
    fi
    if [[ -z "$dest" || ! -f "$dest" ]]; then
        echo "ERROR: migrate-to-overrides: no .env found at ${dest:-<unresolved>}." >&2
        echo "       Run 'gw init' first, or pass --dest PATH explicitly." >&2
        exit 1
    fi
    # Default overrides location: sibling of $dest with the canonical
    # overrides name. Honors $FLAG_OVERRIDES_DEST when set.
    if [[ -n "${FLAG_OVERRIDES_DEST:-}" ]]; then
        overrides_dest="$FLAG_OVERRIDES_DEST"
    else
        local dest_dir; dest_dir="$(dirname "$dest")"
        # Map the dest filename back to the canonical overrides filename:
        #   $GW_HOME/.env → $GW_HOME/overrides.env
        #   ./.env        → ./overrides.env
        # Per-user installs resolve to "$GW_HOME/overrides.env"; project-local
        # installs use "./overrides.env". The default search list
        # (DEFAULT_OVERRIDES_PATHS) honors both shapes, so the runtime loader
        # picks this up automatically.
        overrides_dest="$dest_dir/overrides.env"
    fi

    # Idempotency: if overrides exists AND dest is bit-identical to the
    # template, nothing to do. Use diff's exit status rather than parsing
    # stdout so the check stays terse.
    if [[ -f "$overrides_dest" ]] && diff -q "$dest" "$template" >/dev/null 2>&1; then
        echo "already migrated (no-op)"
        echo "  dest:      $dest"
        echo "  overrides: $overrides_dest"
        return 0
    fi

    # Build the migration list: every uncommented key in dest whose value
    # differs from the template default. Bash 3.2 — no associative arrays;
    # use a space-separated string.
    local migrations=""
    local k cur def
    while IFS= read -r k; do
        [[ -n "$k" ]] || continue
        env_is_uncommented "$dest" "$k" || continue
        cur="$(extract_env_any "$dest" "$k" 2>/dev/null || true)"
        def="$(extract_default_value "$template" "$k" 2>/dev/null || echo "<MISSING>")"
        if [[ "$cur" != "$def" ]]; then
            migrations="${migrations:+$migrations }$k"
        fi
    done < <(env_keys_present "$dest")

    # Always carry the load-bearing secrets across if they're uncommented in
    # the source file, even when their value coincidentally matches the
    # template placeholder. They're per-install and never "default" in any
    # meaningful sense.
    for k in AUTH_TOKEN PII_HASH_KEY; do
        if env_is_uncommented "$dest" "$k"; then
            case " $migrations " in
                *" $k "*) ;;
                *) migrations="${migrations:+$migrations }$k" ;;
            esac
        fi
    done

    if [[ -z "$migrations" ]]; then
        echo "migrate-to-overrides: nothing to migrate (no operator-set keys differ from template defaults)."
        echo "  dest:      $dest"
        echo "  overrides: $overrides_dest"
        return 0
    fi

    echo "gw migrate-to-overrides:"
    echo "  dest:      $dest"
    echo "  overrides: $overrides_dest"
    echo "  would migrate: $migrations"

    if [[ "${FLAG_DRY_RUN:-0}" == "1" ]]; then
        echo "(dry-run; no changes written)"
        return 0
    fi

    # Confirm destructive overwrite of $dest. The overrides file is
    # append-or-create (set_overrides_line) so it's not in the confirm scope.
    if [[ "${FLAG_YES:-0}" != "1" ]]; then
        local reply
        read -r -p "Backup $dest and regenerate from template? [y/N]: " reply
        case "$reply" in
            [Yy]|[Yy][Ee][Ss]) ;;
            *) echo "cancelled" >&2; exit 1 ;;
        esac
    fi

    # Backup BEFORE any disk mutation so a SIGKILL leaves the operator with
    # both files intact and a clear recovery path.
    local backup
    backup="${dest}.pre-migrate.$(date -u +%Y%m%dT%H%M%SZ)"
    cp "$dest" "$backup"
    echo "  backup: $backup"

    # Write migrations to overrides — set_overrides_line creates the file
    # with a header + 0600 mode when missing, and re-asserts the mode on
    # rewrites.
    local v
    for k in $migrations; do
        v="$(extract_env_any "$dest" "$k" 2>/dev/null || true)"
        set_overrides_line "$overrides_dest" "$k" "$v"
    done

    # Regenerate dest as a pure template copy (the new contract).
    cp "$template" "$dest"
    chmod 644 "$dest"

    # Count words in $migrations safely (avoid wc/tr quirks when empty).
    local count=0
    for k in $migrations; do count=$((count + 1)); done
    echo "✓ migrated $count key(s) to $overrides_dest"
    echo "✓ regenerated $dest from template"
    echo "✓ backup at  $backup"
}

# init writes a starter .env file populated with sensible defaults and
# freshly-generated AUTH_TOKEN + PII_HASH_KEY. Designed as the very
# first command a new operator runs after extracting the tarball.
#
# Flags (all optional; unspecified values are prompted interactively
# unless --non-interactive is passed):
#   --dest PATH         where to write (default: $GW_HOME/.env)
#   --here              shortcut for --dest ./.env
#   --force             overwrite if dest exists
#   --auth-token TOK    use TOK instead of generating
#   --hash-key KEY      use KEY instead of generating
#   --encrypt-key KEY   PII_ENCRYPT_KEY value (required when --pii encrypt;
#                       operator-supplied -- NOT minted by --regenerate-secrets)
#   --kiro PATH         KIRO_CMD value
#   --addr ADDR         HTTP_ADDR value (default 127.0.0.1:18080)
#   --pii MODE          off|replace|mask|hash|drop|encrypt  (default encrypt)
#   --auth-enabled      enable bearer-token auth (default off; AUTH_TOKEN
#                       line is pregenerated but written commented when
#                       disabled so flipping a '#' enables it later)
#   --chat-trace        enable chat-trace NDJSON tracer (default off; records
#                       raw user content to chat-trace.log -- sensitive)
#   --regenerate-secrets  on re-init (--force on an existing dest), mint
#                       fresh AUTH_TOKEN + PII_HASH_KEY. Default on re-init
#                       is to PRESERVE the existing secrets so clients and
#                       hash-mode correlation don't break.
#   --non-interactive   don't prompt; use defaults for anything unset
init_cmd() {
    local dest="${GW_HOME}/.env"
    local force=0
    local non_interactive=0
    local arg_auth_token="" arg_hash_key="" arg_encrypt_key="" arg_kiro="" arg_addr="" arg_pii=""
    local arg_auth_enabled=0 arg_chat_trace=0 arg_regenerate_secrets=0

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --dest)              dest="$2"; shift 2 ;;
            --dest=*)            dest="${1#*=}"; shift ;;
            --here)              dest="./.env"; shift ;;
            --force)             force=1; shift ;;
            --non-interactive)   non_interactive=1; shift ;;
            --auth-enabled)      arg_auth_enabled=1; shift ;;
            --auth-token)        arg_auth_token="$2"; arg_auth_enabled=1; shift 2 ;;
            --auth-token=*)      arg_auth_token="${1#*=}"; arg_auth_enabled=1; shift ;;
            --chat-trace)        arg_chat_trace=1; shift ;;
            --regenerate-secrets) arg_regenerate_secrets=1; shift ;;
            --hash-key)          arg_hash_key="$2"; shift 2 ;;
            --hash-key=*)        arg_hash_key="${1#*=}"; shift ;;
            --encrypt-key)       arg_encrypt_key="$2"; shift 2 ;;
            --encrypt-key=*)     arg_encrypt_key="${1#*=}"; shift ;;
            --kiro)              arg_kiro="$2"; shift 2 ;;
            --kiro=*)            arg_kiro="${1#*=}"; shift ;;
            --addr)              arg_addr="$2"; shift 2 ;;
            --addr=*)            arg_addr="${1#*=}"; shift ;;
            --pii)               arg_pii="$2"; shift 2 ;;
            --pii=*)             arg_pii="${1#*=}"; shift ;;
            --idle-timeout)      arg_idle_timeout="$2"; shift 2 ;;
            --idle-timeout=*)    arg_idle_timeout="${1#*=}"; shift ;;
            *)                   echo "init: unknown flag: $1" >&2; exit 1 ;;
        esac
    done

    if [[ -e "$dest" && "$force" -ne 1 ]]; then
        echo "ERROR: $dest already exists. Re-run with --force to overwrite." >&2
        exit 1
    fi

    # Re-init detection: --force on an existing dest. Parse existing values
    # so they can serve as prompt/non-interactive defaults (CLI flag wins;
    # existing-file value is the next-best default; cold-start default is
    # only used when neither is present). Secrets (AUTH_TOKEN, PII_HASH_KEY)
    # are reused verbatim unless --regenerate-secrets — avoids invalidating
    # client tokens and breaking hash-mode log correlation on a casual
    # `init --force` to e.g. flip PII mode.
    local reinit=0
    local existing_kiro="" existing_addr="" existing_pii_mode=""
    local existing_auth_token="" existing_hash_key="" existing_encrypt_key="" existing_pii_enabled=""
    local existing_auth_enabled="" existing_chat_trace=""
    local existing_idle_timeout=""

    # Pre-resolve the overrides path so existing-value lookup can read from
    # BOTH dest AND overrides_dest, with overrides winning on conflict
    # (matches runtime loader precedence). Honors --overrides-dest.
    local _existing_overrides_dest=""
    if [[ -n "${FLAG_OVERRIDES_DEST:-}" ]]; then
        _existing_overrides_dest="$FLAG_OVERRIDES_DEST"
    else
        local _existing_dest_dir; _existing_dest_dir="$(dirname "$dest")"
        _existing_overrides_dest="$_existing_dest_dir/overrides.env"
    fi

    # Inline helper: read KEY from $dest first, then $_existing_overrides_dest
    # (if present); overrides value wins. Echoes the resolved value.
    _extract_existing() {
        local _k="$1" _v_dest="" _v_over=""
        _v_dest="$(extract_env_any "$dest" "$_k" 2>/dev/null || true)"
        if [[ -f "$_existing_overrides_dest" ]]; then
            _v_over="$(extract_env_any "$_existing_overrides_dest" "$_k" 2>/dev/null || true)"
        fi
        if [[ -n "$_v_over" ]]; then
            printf '%s' "$_v_over"
        else
            printf '%s' "$_v_dest"
        fi
    }
    # Sibling: "is KEY uncommented in EITHER dest or overrides_dest?"
    _existing_uncommented() {
        local _k="$1"
        if env_is_uncommented "$dest" "$_k"; then return 0; fi
        if [[ -f "$_existing_overrides_dest" ]] && env_is_uncommented "$_existing_overrides_dest" "$_k"; then return 0; fi
        return 1
    }

    if [[ "$force" -eq 1 && -e "$dest" ]]; then
        if [[ ! -r "$dest" ]]; then
            echo "ERROR: $dest exists but is not readable. Check file permissions." >&2
            exit 1
        fi
        reinit=1
        existing_kiro="$(_extract_existing KIRO_CMD)"
        existing_addr="$(_extract_existing HTTP_ADDR)"
        existing_pii_mode="$(_extract_existing PII_REDACTION_MODE)"
        existing_pii_enabled="$(_extract_existing PII_REDACTION_ENABLED)"
        # Two-knob model: a disabled file is "off" regardless of the stored
        # mode, so re-init preserves "off" instead of resurrecting the
        # placeholder mode we write when disabled.
        case "$existing_pii_enabled" in
            false|FALSE|False|0) existing_pii_mode="off" ;;
        esac
        existing_auth_token="$(_extract_existing AUTH_TOKEN)"
        existing_hash_key="$(_extract_existing PII_HASH_KEY)"
        existing_encrypt_key="$(_extract_existing PII_ENCRYPT_KEY)"
        # STREAM_IDLE_TIMEOUT_SEC is only "operator-set" when it's uncommented
        # in EITHER file. extract_env_any matches commented forms, so without
        # this gate a virgin install would read "30" out of the template's
        # commented default and then write it to overrides on re-init — a
        # Rule-1 bug (Task 3 in 260531-tl1). Keep empty when commented so the
        # idle-timeout block below leaves the template's commented default
        # in place.
        if _existing_uncommented STREAM_IDLE_TIMEOUT_SEC; then
            existing_idle_timeout="$(_extract_existing STREAM_IDLE_TIMEOUT_SEC)"
        else
            existing_idle_timeout=""
        fi
        if _existing_uncommented AUTH_TOKEN; then
            existing_auth_enabled=1
        else
            existing_auth_enabled=0
        fi
        # CHAT_TRACE is "enabled" only when the line is uncommented (in
        # either file) AND the value parses to true.
        if _existing_uncommented CHAT_TRACE; then
            local existing_chat_val
            existing_chat_val="$(_extract_existing CHAT_TRACE)"
            case "$existing_chat_val" in
                true|TRUE|True|1|yes) existing_chat_trace=1 ;;
                *)                    existing_chat_trace=0 ;;
            esac
        else
            existing_chat_trace=0
        fi
        echo "re-init detected: preserving existing values where unchanged"
        if [[ "$arg_regenerate_secrets" -eq 1 ]]; then
            echo "regenerating AUTH_TOKEN, PII_HASH_KEY, and PII_ENCRYPT_KEY (existing values discarded)"
        else
            echo "(use --regenerate-secrets to mint new AUTH_TOKEN / PII_HASH_KEY / PII_ENCRYPT_KEY)"
        fi
    fi

    # Generate secrets — precedence: CLI flag > existing-file value (re-init,
    # unless --regenerate-secrets) > fresh random.
    local auth_token="$arg_auth_token"
    local auth_token_preserved=0
    if [[ -z "$auth_token" ]]; then
        if [[ "$reinit" -eq 1 && "$arg_regenerate_secrets" -ne 1 && -n "$existing_auth_token" ]]; then
            auth_token="$existing_auth_token"
            auth_token_preserved=1
        else
            auth_token="$(gen_random_hex 32)"
        fi
    fi
    local hash_key="$arg_hash_key"
    local hash_key_preserved=0
    if [[ -z "$hash_key" ]]; then
        if [[ "$reinit" -eq 1 && "$arg_regenerate_secrets" -ne 1 && -n "$existing_hash_key" ]]; then
            hash_key="$existing_hash_key"
            hash_key_preserved=1
        else
            hash_key="$(gen_random_hex 32)"
        fi
    fi
    # PII_ENCRYPT_KEY is auto-generated when missing — same precedence as
    # AUTH_TOKEN and PII_HASH_KEY. Generated even when the current mode
    # isn't encrypt, so a later 'gw start --pii encrypt' (or a
    # PII_ENTITY_ACTIONS entry adding :encrypt) works without re-init.
    # --regenerate-secrets discards the existing value.
    local encrypt_key="$arg_encrypt_key"
    local encrypt_key_preserved=0
    if [[ -z "$encrypt_key" ]]; then
        if [[ "$reinit" -eq 1 && "$arg_regenerate_secrets" -ne 1 && -n "$existing_encrypt_key" ]]; then
            encrypt_key="$existing_encrypt_key"
            encrypt_key_preserved=1
        else
            encrypt_key="$(gen_random_hex 32)"
        fi
    fi

    # Resolve KIRO_CMD — precedence: CLI flag > existing-file value (re-init)
    # > interactive prompt with `command -v kiro-cli` suggestion > empty.
    local kiro_cmd="$arg_kiro"
    if [[ -z "$kiro_cmd" ]]; then
        if [[ -n "$existing_kiro" ]]; then
            if [[ "$non_interactive" -eq 1 ]]; then
                kiro_cmd="$existing_kiro"
            else
                read -r -p "  kiro-cli path [$existing_kiro]: " kiro_cmd
                [[ -z "$kiro_cmd" ]] && kiro_cmd="$existing_kiro"
            fi
        elif [[ "$non_interactive" -ne 1 ]]; then
            local kiro_default; kiro_default="$(command -v kiro-cli 2>/dev/null || true)"
            read -r -p "  kiro-cli path [${kiro_default:-press Enter to leave unset}]: " kiro_cmd
            [[ -z "$kiro_cmd" ]] && kiro_cmd="$kiro_default"
        fi
    fi

    # Resolve HTTP_ADDR — precedence: CLI flag > existing > prompt > default.
    local http_addr="$arg_addr"
    if [[ -z "$http_addr" ]]; then
        if [[ -n "$existing_addr" ]]; then
            if [[ "$non_interactive" -eq 1 ]]; then
                http_addr="$existing_addr"
            else
                read -r -p "  HTTP_ADDR [$existing_addr]: " http_addr
                [[ -z "$http_addr" ]] && http_addr="$existing_addr"
            fi
        elif [[ "$non_interactive" -ne 1 ]]; then
            echo "  HTTP listen address -- default 127.0.0.1:18080 (safe, no collision)."
            echo "  Set to 127.0.0.1:11434 if migrating from the Node Ollama proxy."
            read -r -p "  HTTP_ADDR [127.0.0.1:18080]: " http_addr
        fi
    fi
    [[ -z "$http_addr" ]] && http_addr="127.0.0.1:18080"

    # Resolve PII mode — precedence: CLI flag > existing > prompt > "encrypt".
    # Default is encrypt: PII flows to the LLM as AES-256-GCM ciphertext and is
    # decrypted back to plaintext before the client sees the response (round-
    # trip). PII_ENCRYPT_KEY is auto-generated below if missing.
    local pii_mode="$arg_pii"
    if [[ -z "$pii_mode" ]]; then
        if [[ -n "$existing_pii_mode" ]]; then
            if [[ "$non_interactive" -eq 1 ]]; then
                pii_mode="$existing_pii_mode"
            else
                read -r -p "  PII mode [$existing_pii_mode]: " pii_mode
                [[ -z "$pii_mode" ]] && pii_mode="$existing_pii_mode"
            fi
        elif [[ "$non_interactive" -ne 1 ]]; then
            echo "  PII redaction -- off | replace | mask | hash | drop | encrypt."
            echo "  'encrypt' (default) hides PII from the LLM and decrypts the response back to plaintext;"
            echo "  'hash' correlates values across logs; 'replace' is human-readable; 'off' disables."
            read -r -p "  PII mode [encrypt]: " pii_mode
        fi
    fi
    [[ -z "$pii_mode" ]] && pii_mode="encrypt"

    # Validate mode early so a typo doesn't write garbage to overrides. The
    # gateway also validates at boot, but catching it here keeps the error
    # close to the operator's input.
    case "$pii_mode" in
        off|replace|mask|hash|drop|encrypt) ;;
        *) echo "ERROR: --pii must be one of off|replace|mask|hash|drop|encrypt (got: $pii_mode)" >&2; exit 1 ;;
    esac

    local pii_enabled="false"
    [[ "$pii_mode" != "off" ]] && pii_enabled="true"
    # PII_REDACTION_MODE must be a valid mode (replace|mask|hash|drop|encrypt)
    # even when redaction is disabled — config.Load validates it unconditionally.
    # "off" is expressed via PII_REDACTION_ENABLED=false, so write a harmless
    # valid placeholder for the mode when off.
    local pii_mode_value="$pii_mode"
    [[ "$pii_mode" == "off" ]] && pii_mode_value="replace"

    # Resolve AUTH state — precedence: CLI flag (--auth-enabled / --auth-token)
    # > existing-file state (uncommented = enabled) > interactive prompt > off.
    local auth_enabled="$arg_auth_enabled"
    if [[ "$auth_enabled" -eq 0 && -n "$existing_auth_enabled" ]]; then
        auth_enabled="$existing_auth_enabled"
        # On re-init, also honor the existing state without re-prompting unless
        # the operator passed an explicit flag (handled by the precedence above).
    elif [[ "$auth_enabled" -eq 0 && "$non_interactive" -ne 1 ]]; then
        echo "  Bearer-token auth -- when enabled, every request must carry"
        echo "  'Authorization: Bearer <token>'. Off is fine for local/laptop use."
        read -r -p "  Enable auth? [y/N]: " auth_reply
        case "$auth_reply" in
            [Yy]|[Yy][Ee][Ss]) auth_enabled=1 ;;
            *) auth_enabled=0 ;;
        esac
    fi
    # Resolve CHAT_TRACE state — precedence: --chat-trace flag > existing-file
    # state (uncommented + true = enabled) > interactive prompt > off.
    local chat_trace="$arg_chat_trace"
    if [[ "$chat_trace" -eq 0 && -n "$existing_chat_trace" ]]; then
        chat_trace="$existing_chat_trace"
    elif [[ "$chat_trace" -eq 0 && "$non_interactive" -ne 1 ]]; then
        echo "  Chat-trace -- records raw user content (pre-redaction) to a"
        echo "  separate chat-trace.log for debugging. Sensitive: 0600 mode,"
        echo "  3-day default retention. Off is fine for normal use."
        read -r -p "  Enable chat-trace? [y/N]: " chat_reply
        case "$chat_reply" in
            [Yy]|[Yy][Ee][Ss]) chat_trace=1 ;;
            *) chat_trace=0 ;;
        esac
    fi
    local chat_trace_value="false"
    if [[ "$chat_trace" -eq 1 ]]; then
        chat_trace_value="true"
    fi

    # Resolve STREAM_IDLE_TIMEOUT_SEC — precedence: --idle-timeout flag >
    # existing-file value > default "30" commented. CLI/existing values are
    # written uncommented (operator tuning preserved); the default is
    # commented so it's discoverable but doesn't override the binary
    # default unless explicitly set.
    local idle_timeout_value="30"
    local idle_timeout_commented="1"
    if [[ -n "${arg_idle_timeout:-}" ]]; then
        idle_timeout_value="$arg_idle_timeout"
        idle_timeout_commented="0"
    elif [[ -n "$existing_idle_timeout" ]]; then
        idle_timeout_value="$existing_idle_timeout"
        idle_timeout_commented="0"
    fi

    # When chat-trace is enabled, ChatTraceHook must be in ENABLED_HOOKS
    # (chain.Filter strips it otherwise). Prepend so the load-bearing
    # "first in Pre" invariant is preserved. The config-level symmetric
    # rule (config.go) also handles this at runtime, but writing the
    # accurate list to the file keeps the operator-facing surface honest.
    local enabled_hooks_value="RequestIDHook,AuthHook,JSONFormatSteeringHook,PIIRedactionHook,LoggingHook"
    if [[ "$chat_trace" -eq 1 ]]; then
        enabled_hooks_value="ChatTraceHook,RequestIDHook,AuthHook,JSONFormatSteeringHook,PIIRedactionHook,LoggingHook"
    fi

    # Ensure template exists — it is the single source of truth for the key list.
    # Respect --template if the operator overrode it via parse_flags above.
    local template_file
    if ! template_file="$(resolve_template_file)"; then
        local sought="${TEMPLATE_FILE_OVERRIDE:-${GW_TEMPLATE_FILE:-$GW_SCRIPT_DIR/.env.example}}"
        echo "ERROR: init template not found: $sought" >&2
        echo "       The file scripts/.env.example must ship alongside gw." >&2
        exit 1
    fi

    # Ensure parent dir exists.
    local dest_dir; dest_dir="$(dirname "$dest")"
    [[ -n "$dest_dir" && "$dest_dir" != "." ]] && mkdir -p "$dest_dir"

    # Two-file model contract (260531-tl1 CONTEXT.md Decision 5 + Q3):
    #   - `.env` is ALWAYS a byte-for-byte template copy. No
    #     set_env_line writes happen against it. mode 0644.
    #   - `overrides.env` carries every operator customization
    #     (uncommented) — secrets always, other knobs only when the
    #     operator explicitly set them or the install came in via re-init
    #     migration. mode 0600.

    # Resolve overrides_dest. Default = sibling of $dest with the canonical
    # overrides name. Honors --overrides-dest (FLAG_OVERRIDES_DEST).
    local overrides_dest
    if [[ -n "${FLAG_OVERRIDES_DEST:-}" ]]; then
        overrides_dest="$FLAG_OVERRIDES_DEST"
    else
        overrides_dest="$dest_dir/overrides.env"
    fi

    # Pre-flight migration: re-init on a legacy single-file install. If
    # --force AND $dest exists AND no overrides file is present AND the
    # dest has uncommented operator values, run a silent migration BEFORE
    # the normal init flow. This means a v1.6.10 → current `init --force`
    # auto-migrates without a separate command. One INFO line surfaces
    # what happened so it's never invisible.
    if [[ "$reinit" -eq 1 && ! -f "$overrides_dest" ]]; then
        local pre_migrate_needed=0
        # Quick heuristic — any of these uncommented (and the secret values
        # not at the template placeholder) ⇒ migrate.
        if env_is_uncommented "$dest" AUTH_TOKEN || \
           env_is_uncommented "$dest" KIRO_CMD || \
           env_is_uncommented "$dest" PII_HASH_KEY || \
           env_is_uncommented "$dest" HTTP_ADDR; then
            pre_migrate_needed=1
        fi
        if [[ "$pre_migrate_needed" -eq 1 ]]; then
            echo "note: detected pre-overrides install — migrating to overrides model"
            local pre_backup
            pre_backup="${dest}.pre-migrate.$(date -u +%Y%m%dT%H%M%SZ)"
            cp "$dest" "$pre_backup"
            local mk_pre mv_pre def_pre
            while IFS= read -r mk_pre; do
                [[ -n "$mk_pre" ]] || continue
                env_is_uncommented "$dest" "$mk_pre" || continue
                mv_pre="$(extract_env_any "$dest" "$mk_pre" 2>/dev/null || true)"
                def_pre="$(extract_default_value "$template_file" "$mk_pre" 2>/dev/null || echo "<MISSING>")"
                if [[ "$mv_pre" != "$def_pre" ]]; then
                    set_overrides_line "$overrides_dest" "$mk_pre" "$mv_pre"
                fi
            done < <(env_keys_present "$dest")
            # Always preserve secrets across the auto-migration.
            for mk_pre in AUTH_TOKEN PII_HASH_KEY; do
                if env_is_uncommented "$dest" "$mk_pre"; then
                    mv_pre="$(extract_env_any "$dest" "$mk_pre" 2>/dev/null || true)"
                    [[ -n "$mv_pre" ]] && set_overrides_line "$overrides_dest" "$mk_pre" "$mv_pre"
                fi
            done
            echo "  pre-init backup: $pre_backup"
            echo "  overrides:       $overrides_dest"
        fi
    fi

    # Step 1: regenerate $dest as a byte-for-byte template copy.
    cp "$template_file" "$dest"
    chmod 644 "$dest"

    # Step 2: write each operator customization to $overrides_dest. Rules
    # follow Q3's "always write to overrides" decision:
    #   - Secrets ALWAYS land in overrides (PII_HASH_KEY always; AUTH_TOKEN
    #     only when auth is enabled).
    #   - PII_REDACTION_ENABLED + PII_REDACTION_MODE always land — operator
    #     decisions even at defaults.
    #   - Other knobs (HTTP_ADDR, KIRO_CMD, CHAT_TRACE, ENABLED_HOOKS,
    #     STREAM_IDLE_TIMEOUT_SEC) only when set to a non-default /
    #     non-empty value.
    if [[ "$auth_enabled" -eq 1 ]]; then
        set_overrides_line "$overrides_dest" AUTH_TOKEN "$auth_token"
    fi
    set_overrides_line "$overrides_dest" PII_HASH_KEY "$hash_key"
    # PII_ENCRYPT_KEY is now always seeded (encrypt is the default mode)
    # so the gateway boots without operator intervention. The key is
    # auto-generated above on cold init; preserved on re-init; rotated
    # by --regenerate-secrets.
    set_overrides_line "$overrides_dest" PII_ENCRYPT_KEY "$encrypt_key"
    set_overrides_line "$overrides_dest" PII_REDACTION_ENABLED "$pii_enabled"
    set_overrides_line "$overrides_dest" PII_REDACTION_MODE "$pii_mode_value"
    if [[ -n "$kiro_cmd" ]]; then
        set_overrides_line "$overrides_dest" KIRO_CMD "$kiro_cmd"
    fi
    if [[ -n "$http_addr" ]]; then
        set_overrides_line "$overrides_dest" HTTP_ADDR "$http_addr"
    fi
    if [[ "$chat_trace" -eq 1 ]]; then
        set_overrides_line "$overrides_dest" CHAT_TRACE "$chat_trace_value"
        # ChatTraceHook prefix is load-bearing when chat-trace is on
        # (chain.Filter strips it otherwise); write only when needed.
        set_overrides_line "$overrides_dest" ENABLED_HOOKS "$enabled_hooks_value"
    fi
    if [[ "$idle_timeout_commented" == "0" ]]; then
        set_overrides_line "$overrides_dest" STREAM_IDLE_TIMEOUT_SEC "$idle_timeout_value"
    fi

    # set_overrides_line already chmod 600's after each write, but
    # re-assert for the pre-existing-file case (idempotent).
    chmod 600 "$overrides_dest" 2>/dev/null || true

    echo "✓ wrote $dest                  (template copy, mode 0644)"
    echo "✓ wrote $overrides_dest  (operator config + secrets, mode 0600)"
    if [[ "$auth_enabled" -eq 1 ]]; then
        if [[ "$auth_token_preserved" -eq 1 ]]; then
            echo "  AUTH:          enabled (token preserved from prior install)"
        else
            echo "  AUTH:          enabled (AUTH_TOKEN=$(echo "$auth_token" | head -c 8)… in overrides)"
        fi
    else
        echo "  AUTH:          disabled (no AUTH_TOKEN in overrides; commented placeholder in .env)"
    fi
    if [[ "$hash_key_preserved" -eq 1 ]]; then
        echo "  PII_HASH_KEY:  preserved (existing key reused)"
    else
        echo "  PII_HASH_KEY:  $(echo "$hash_key" | head -c 8)…(generated)"
    fi
    if [[ -n "$encrypt_key" ]]; then
        if [[ "$encrypt_key_preserved" -eq 1 ]]; then
            echo "  PII_ENCRYPT_KEY: preserved (existing key reused)"
        else
            echo "  PII_ENCRYPT_KEY: $(echo "$encrypt_key" | head -c 8)…(operator-supplied)"
        fi
    elif [[ "$pii_mode" == "encrypt" ]]; then
        echo "  PII_ENCRYPT_KEY: (unset -- gateway will refuse to start in encrypt mode without one)" >&2
        echo "                  Pass --encrypt-key KEY, or set PII_ENCRYPT_KEY in overrides." >&2
    fi
    if [[ -n "$kiro_cmd" ]]; then
        echo "  KIRO_CMD:      $kiro_cmd"
    else
        echo "  KIRO_CMD:      (unset -- chat will 503 until you set it)"
    fi
    echo "  HTTP_ADDR:     $http_addr"
    echo "  PII:           $pii_mode"
    if [[ "$chat_trace" -eq 1 ]]; then
        echo "  CHAT_TRACE:    enabled (raw content to chat-trace.log -- sensitive)"
    else
        echo "  CHAT_TRACE:    disabled"
    fi
    echo ""
    echo "Next: ./scripts/gw start"
}

# env subcommand: print the resolved gateway-relevant env (KEY=value, one
# per line). Secrets are masked unless --show-secrets is passed.
print_env() {
    load_config
    local show_secrets="${FLAG_SHOW_SECRETS:-0}"
    local k v masked
    for k in ENABLED_HOOKS PII_REDACTION_ENABLED PII_REDACTION_MODE \
             PII_ENABLED_ENTITIES PII_ENTITY_ACTIONS PII_HASH_KEY \
             PII_ENCRYPT_KEY AUTH_TOKEN ALLOWED_IPS \
             AUTH_TRUST_XFF HTTP_ADDR KIRO_CMD KIRO_ARGS KIRO_CWD \
             POOL_SIZE STREAM_IDLE_TIMEOUT_SEC DEBUG; do
        v="${!k:-}"
        if [[ -z "$v" ]]; then
            continue
        fi
        if [[ "$show_secrets" != "1" ]] && [[ "$k" == "AUTH_TOKEN" || "$k" == "PII_HASH_KEY" || "$k" == "PII_ENCRYPT_KEY" ]]; then
            # Show only first 4 chars + char count, never the literal.
            masked="${v:0:4}…(${#v} chars)"
            echo "$k=$masked"
        else
            echo "$k=$v"
        fi
    done
}

# support [--out DIR] [--max-mb N] [--log-days D]
#
# Produce a redacted diagnostic archive at
# $GW_HOME/support/gateway-support-<host>-<ts>.tar.gz plus a
# `support/latest.tar.gz` alias (a copy, NOT a symlink — Windows parity).
#
# Layout (locked by docs/superpowers/specs/2026-06-08-support-bundle-design.md
# §Bundle Layout — six trees + MANIFEST.txt, no extras, no omissions):
#   MANIFEST.txt, env/, health/, logs/, system/, tray/
#
# Redaction rules live in scripts/lib/redact.sh and apply to BOTH the env
# dump and the log copies before they enter the staging tree. The original
# files on disk are never modified. The literal AUTH_TOKEN / PII_HASH_KEY /
# PII_ENCRYPT_KEY values — and any *TOKEN* / *KEY* / *SECRET* / *PASSWORD* /
# *PASSPHRASE* match (case-insensitive) — are masked via mask_env_value.
support() {
    # FLAG_SHOW_SECRETS is referenced defensively below: even if some future
    # caller smuggles --show-secrets into the support path, this local masks
    # it out. The support bundle ALWAYS masks; this is a design constraint
    # (no raw secrets, ever — spec §Constraints).
    local FLAG_SHOW_SECRETS=0
    local FLAG_OUT="" FLAG_MAX_MB=50 FLAG_LOG_DAYS=7
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --out) FLAG_OUT="$2"; shift 2 ;;
            --max-mb) FLAG_MAX_MB="$2"; shift 2 ;;
            --log-days) FLAG_LOG_DAYS="$2"; shift 2 ;;
            -h|--help)
                cat <<'EOF'
Usage: gw support [--out DIR] [--max-mb N] [--log-days D]

Produce a redacted diagnostic archive under $GW_HOME/support/
(or --out DIR). Secrets are masked. No raw values are ever written.

  --out DIR        override output directory (default: $GW_HOME/support)
  --max-mb N       bundle size cap in MB (default 50; oldest rotated logs dropped)
  --log-days D     include rotated .log.gz files modified in last D days (default 7)
EOF
                return 0
                ;;
            *)
                echo "support: unknown flag: $1" >&2
                return 2
                ;;
        esac
    done

    # Source the shared redaction primitives. Same resolution pattern as the
    # rest of the wrapper uses for sibling files.
    # shellcheck source=lib/redact.sh
    source "$GW_SCRIPT_DIR/lib/redact.sh"

    # Resolve config (this also writes "loaded env file:" / "loaded overrides:"
    # to stderr — captured in the bundle's MANIFEST/system area indirectly via
    # env-files.txt). load_config sets KIRO_CMD etc. as side effects.
    load_config

    local ts host out_dir bundle_name staging bundle_root
    ts=$(date -u +%Y%m%d-%H%M%S)
    host=$(hostname -s 2>/dev/null || hostname)
    out_dir="${FLAG_OUT:-$GW_HOME/support}"
    bundle_name="gateway-support-${host}-${ts}"
    staging=$(mktemp -d)
    bundle_root="$staging/$bundle_name"

    # Cleanup the staging dir even on failure. The output archive lives
    # outside the staging dir so this trap does NOT delete it.
    # shellcheck disable=SC2064
    trap "rm -rf '$staging'" EXIT

    mkdir -p "$out_dir" "$bundle_root"/{env,health,logs,system,tray}

    # ---- env/ ----------------------------------------------------------
    # env/effective.env: extend print_env's mask logic to every *TOKEN* /
    # *KEY* / *SECRET* / *PASSWORD* / *PASSPHRASE* env var, not just the
    # explicit three. We DON'T call print_env directly because its mask
    # surface is intentionally small (only the explicit three) — the
    # support bundle's stricter mask is a defense-in-depth requirement.
    {
        local k v
        for k in ENABLED_HOOKS PII_REDACTION_ENABLED PII_REDACTION_MODE \
                 PII_ENABLED_ENTITIES PII_ENTITY_ACTIONS PII_HASH_KEY \
                 PII_ENCRYPT_KEY AUTH_TOKEN ALLOWED_IPS \
                 AUTH_TRUST_XFF HTTP_ADDR KIRO_CMD KIRO_ARGS KIRO_CWD \
                 POOL_SIZE STREAM_IDLE_TIMEOUT_SEC DEBUG CHAT_TRACE \
                 GW_ENV_FILE_LOADED GW_OVERRIDES_FILE_LOADED; do
            v="${!k:-}"
            [[ -z "$v" ]] && continue
            if is_secret_key "$k"; then
                echo "$k=$(mask_env_value "$v")"
            else
                echo "$k=$v"
            fi
        done
    } > "$bundle_root/env/effective.env"

    # env/env-files.txt: which resolver actually hit.
    {
        local ef of
        ef="$(resolve_env_file)"
        of="$(resolve_overrides_file)"
        echo "env file:       ${ef:-(none)}"
        echo "overrides file: ${of:-(none)}"
    } > "$bundle_root/env/env-files.txt"

    # env/shell-env.txt: ambient shell vars in the GW_/KIRO_/PII_/AUTH_/
    # ALLOWED_/HTTP_ADDR/DEBUG/CHAT_TRACE namespaces, redacted. We can't
    # iterate `env` output verbatim because that dumps the FULL environment
    # (PATH, HOME, etc.); filtering by prefix keeps the surface bounded.
    {
        local line key val
        while IFS= read -r line; do
            # Strip everything from '=' to EOL to isolate the key for the
            # secret-test, but keep the original line around for output.
            key="${line%%=*}"
            if [[ -z "$key" || "$key" == "$line" ]]; then continue; fi
            # Only keep keys in the GW/KIRO/PII/AUTH/ALLOWED namespace,
            # plus the explicit HTTP_ADDR / DEBUG / CHAT_TRACE singletons.
            case "$key" in
                GW_*|KIRO_*|PII_*|AUTH_*|ALLOWED_*|HTTP_ADDR|DEBUG|CHAT_TRACE) ;;
                *) continue ;;
            esac
            val="${line#*=}"
            if is_secret_key "$key"; then
                echo "$key=$(mask_env_value "$val")"
            else
                echo "$key=$val"
            fi
        done < <(env | sort)
    } > "$bundle_root/env/shell-env.txt"

    # ---- health/ -------------------------------------------------------
    # status() exits non-zero when the gateway is stopped (so `gw status`
    # in a shell pipeline returns a useful code). We don't want the support
    # subcommand to abort on a stopped gateway. With `set -e` active, a bare
    # `( status 2>&1 || true ) > file` still propagates the subshell exit
    # through the enclosing function — bash's set-e-in-subshell-in-function
    # gotcha. Capturing via `$( ... || true )` is the documented escape:
    # command substitution always treats the subshell exit as a value, not
    # a fail-fast trigger.
    local status_out
    status_out=$( ( status 2>&1 ) || true )
    printf '%s\n' "$status_out" > "$bundle_root/health/status.txt"

    # health.json / snapshot.json: best-effort live probe. On failure write
    # an "unreachable: <reason>" sentinel so triage can tell "no probe ran"
    # from "probe ran and got an empty body".
    if curl -sf -m 5 "${GW_ADDR}/health" > "$bundle_root/health/health.json" 2>/dev/null; then
        :
    else
        echo "unreachable: ${GW_ADDR}/health did not respond within 5s" > "$bundle_root/health/health.json"
    fi
    if curl -sf -m 5 "${GW_ADDR}/admin/api/snapshot" > "$bundle_root/health/snapshot.json" 2>/dev/null; then
        :
    else
        echo "unreachable: ${GW_ADDR}/admin/api/snapshot did not respond within 5s" > "$bundle_root/health/snapshot.json"
    fi

    # ---- logs/ ---------------------------------------------------------
    # Copy through redact_stream so masked tokens are in the bundle but the
    # source files on disk stay verbatim (operators sometimes need to grep
    # their own logs with the real values). Missing source files are silently
    # skipped — common during early-life installs.
    local logs_dir; logs_dir="$(dirname "$GW_LOG")"
    local chat_trace_log; chat_trace_log="${GW_LOG%.log}-chat-trace.log"
    local src dst
    for pair in \
        "$GW_LOG:gateway.log" \
        "$GW_LOG_BOOT:gateway-boot.log" \
        "$chat_trace_log:gateway-chat-trace.log"; do
        src="${pair%%:*}"
        dst="${pair##*:}"
        if [[ -f "$src" ]]; then
            redact_stream < "$src" > "$bundle_root/logs/$dst"
        fi
    done

    # Rotated *.log.gz within the --log-days window. -mtime -N is portable
    # across BSD and GNU find. The wrapper gateway scrubs at write time so
    # we don't gunzip/regzip here (would force gzip in the redaction path
    # and break BSD/GNU portability). MANIFEST notes the deferral.
    if [[ -d "$logs_dir" ]]; then
        find "$logs_dir" -maxdepth 1 -name 'gateway-*.log.gz' -mtime -"$FLAG_LOG_DAYS" -print 2>/dev/null | while IFS= read -r gz; do
            cp -p "$gz" "$bundle_root/logs/" 2>/dev/null || true
        done
    fi

    # ---- system/ -------------------------------------------------------
    {
        echo "uname:    $(uname -a)"
        echo "arch:     $(uname -m)"
        echo "hostname: $host"
        echo "date:     $(date)"
        echo "LANG:     ${LANG:-}"
        echo "LC_ALL:   ${LC_ALL:-}"
        echo "df -h $GW_INSTALL_DIR:"
        df -h "$GW_INSTALL_DIR" 2>/dev/null | tail -n 1 || echo "(unavailable)"
    } > "$bundle_root/system/system.txt"

    {
        echo "gateway:"
        if [[ -x "$GW_BIN" ]]; then
            "$GW_BIN" --version 2>&1 || echo "(--version failed)"
        else
            echo "(binary not found at $GW_BIN)"
        fi
        echo
        echo "kiro-cli:"
        if command -v kiro >/dev/null 2>&1; then
            command -v kiro
            kiro --version 2>&1 || echo "(kiro --version failed)"
        else
            echo "(kiro not on PATH)"
        fi
        echo
        echo "gateway-tray: n/a — query via tray menu (wrapper does not embed tray version)"
    } > "$bundle_root/system/versions.txt"

    # 2-level listing of the install root (per spec). Sorted so triage can
    # diff bundles across captures.
    find "$GW_INSTALL_DIR" -maxdepth 2 -print 2>/dev/null | sort > "$bundle_root/system/installroot.txt"

    # ---- tray/ ---------------------------------------------------------
    # tray/tray-state.txt row removed in v1.10.3 per REL-TRAY-09 (D-18-10):
    # read $GW_INSTALL_DIR/.otto/tray/state, a file the tray has never
    # written. Every bundle showed "(unavailable: ... does not exist)".
    # tray/autostart.txt row removed in v1.10.3 per REL-TRAY-09 (D-18-10):
    # probed com.otto.tray.plist but the actual label is io.cmetech.gateway-tray
    # (cmd/otto-tray/autostart_darwin.go:15). The row always reported the
    # LaunchAgent absent. Re-add when a real macOS LaunchAgent ships.
    {
        echo "pidfile: $GW_PID"
        if [[ -f "$GW_PID" ]]; then
            echo "pid:     $(cat "$GW_PID")"
            # GNU stat uses -c %y, BSD stat uses -f %Sm. Try GNU first; fall
            # back to BSD. Either flavor of failure is fine — best-effort.
            local mtime
            mtime=$(stat -c %y "$GW_PID" 2>/dev/null || stat -f %Sm "$GW_PID" 2>/dev/null || echo "(unavailable)")
            echo "mtime:   $mtime"
        else
            echo "pid:     (no pidfile)"
        fi
    } > "$bundle_root/tray/pidfile.txt"

    # ---- Size cap enforcement -----------------------------------------
    # du -sm yields whole MB. If we're over cap, drop the oldest rotated
    # gz files until we're under, listing each drop in MANIFEST below.
    local dropped_files=()
    local current_mb
    current_mb=$(du -sm "$bundle_root" 2>/dev/null | awk '{print $1}')
    if [[ -n "$current_mb" && "$current_mb" -gt "$FLAG_MAX_MB" ]]; then
        # Sort by mtime ascending (oldest first). BSD `stat -f %m` prints
        # epoch seconds; GNU `stat -c %Y` prints the same. We tab-pair the
        # epoch with the path, sort numerically, then strip the prefix.
        # Fall back gracefully if both flavors miss: filename-sort is
        # deterministic enough for the "we have to drop *something*" case.
        local gz_list gz_path epoch
        gz_list=""
        for gz_path in "$bundle_root/logs/"gateway-*.log.gz; do
            [[ -e "$gz_path" ]] || continue
            epoch=$(stat -f %m "$gz_path" 2>/dev/null || stat -c %Y "$gz_path" 2>/dev/null || echo 0)
            gz_list+="${epoch}	${gz_path}"$'\n'
        done
        if [[ -n "$gz_list" ]]; then
            local sorted
            sorted=$(printf '%s' "$gz_list" | sort -n | awk -F'\t' '{print $2}')
            while IFS= read -r gz; do
                [[ -z "$gz" ]] && continue
                rm -f "$gz"
                dropped_files+=("$gz")
                current_mb=$(du -sm "$bundle_root" 2>/dev/null | awk '{print $1}')
                if [[ -n "$current_mb" && "$current_mb" -le "$FLAG_MAX_MB" ]]; then
                    break
                fi
            done <<< "$sorted"
        fi
    fi

    # Resolve the Gateway ID the same way the gateway does (resolveGatewayID):
    # GW_ID env → $GW_HOME/gateway-id → <UserConfigDir>/gateway/gateway-id
    # (macOS: ~/Library/Application Support; Linux: $XDG_CONFIG_HOME|~/.config).
    # Support triage groups a user's metrics/logs by this id.
    local gw_id="${GW_ID:-}"
    if [[ -z "$gw_id" ]]; then
        local _idf
        for _idf in \
            "$GW_HOME/gateway-id" \
            "${XDG_CONFIG_HOME:-$HOME/.config}/gateway/gateway-id" \
            "$HOME/Library/Application Support/gateway/gateway-id"; do
            if [[ -f "$_idf" ]]; then
                gw_id="$(tr -d '[:space:]' < "$_idf")"
                [[ -n "$gw_id" ]] && break
            fi
        done
    fi
    [[ -z "$gw_id" ]] && gw_id="(unknown)"

    # ---- MANIFEST.txt (written LAST so contents listing is accurate) ---
    {
        echo "gw support bundle"
        echo "======================"
        echo "gateway_id: $gw_id"
        echo "timestamp:  $ts UTC"
        echo "host:       $host"
        echo "os:         $(uname -a)"
        echo "wrapper:    scripts/gw (POSIX bash)"
        echo "spec:       docs/superpowers/specs/2026-06-08-support-bundle-design.md"
        echo
        echo "Redaction notice"
        echo "----------------"
        echo "Env keys masked via scripts/lib/redact.sh:"
        echo "  - AUTH_TOKEN, PII_HASH_KEY, PII_ENCRYPT_KEY (explicit allowlist)"
        echo "  - any key matching *TOKEN* / *KEY* / *SECRET* / *PASSWORD* / *PASSPHRASE* (case-insensitive)"
        echo "Log scrubs (regex -> [REDACTED]):"
        echo "  - Bearer <token>"
        echo "  - ^(AUTH_TOKEN|PII_HASH_KEY|PII_ENCRYPT_KEY)= lines"
        echo "  - Authorization: header values"
        echo "  - x-api-key: header values (case-insensitive)"
        echo
        echo "Rotated *.log.gz files are copied verbatim. Gateway already"
        echo "scrubs at write time, so the on-disk gz files already have"
        echo "masked content — re-redacting would require gunzip/gzip in"
        echo "the bash path and was deferred to keep this wrapper portable."
        echo
        echo "Bundle contents"
        echo "---------------"
        ( cd "$staging" && find "$bundle_name" -maxdepth 3 -print | sort )
        if [[ "${#dropped_files[@]}" -gt 0 ]]; then
            echo
            echo "Dropped for size (>$FLAG_MAX_MB MB cap)"
            echo "--------------------------------------"
            local d
            for d in "${dropped_files[@]}"; do
                echo "DROPPED FOR SIZE: $d"
            done
        fi
    } > "$bundle_root/MANIFEST.txt"

    # ---- Archive --------------------------------------------------------
    local out_path="$out_dir/$bundle_name.tar.gz"
    if ! tar -czf "$out_path" -C "$staging" "$bundle_name"; then
        echo "support: tar failed for $out_path" >&2
        return 1
    fi
    # latest.tar.gz is a COPY (not a symlink) for parity with the Windows
    # wrapper's Copy-Item — design constraint §Output Location.
    cp -f "$out_path" "$out_dir/latest.tar.gz"

    echo "$out_path"
    return 0
}

usage() {
    local exit_code="${1:-1}"
    if [[ "$exit_code" -eq 0 ]]; then
        cat <<'EOF'
Usage: gw <command> [flags]

Commands:
  init [flags]        First-run setup — generates AUTH_TOKEN + PII_HASH_KEY,
                      prompts for KIRO_CMD + HTTP_ADDR, writes a .env file.
  start [flags]       Start gateway in background (waits for /health)
  stop                Stop background gateway (also reaps any stray $KIRO_CMD subprocesses)
  status              Show gateway status and health
  restart [flags]     Stop then start (re-applies flags / .env)
  logs [-f]           Tail gateway log (optional -f to follow)
  run [flags]         Run gateway in foreground
  env [--show-secrets]
                      Print the resolved gateway env that would be passed
  upgrade-env [flags] Regenerate .env from the latest .env.example
                      template. Operator customizations in overrides.env
                      are NEVER touched. --dry-run shows the added / orphaned /
                      unchanged keys without writing.
  migrate-to-overrides [flags]
                      One-time migration from the legacy single-file model:
                      extract non-default values from .env into
                      overrides.env, back up the original, then
                      regenerate .env from the template. Idempotent.
  version             Print the gateway binary version (delegates to bin/gateway --version)
  support [--out DIR] [--max-mb N] [--log-days D]
                      Produce a redacted diagnostic archive under
                      $GW_HOME/support/. Secrets are masked. No raw
                      values are ever written. See
                      docs/superpowers/specs/2026-06-08-support-bundle-design.md.

Gateway config flags (for start | restart | run | env):
  --pii MODE          off | replace | mask | hash | drop | encrypt
  --hash-key KEY      PII_HASH_KEY (required when --pii hash)
  --encrypt-key KEY   PII_ENCRYPT_KEY (required when --pii encrypt; any
                      non-empty string -- gateway derives a 32-byte
                      AES-256-GCM key via SHA-256 at boot)
  --entities LIST     PII_ENABLED_ENTITIES (comma list)
  --hooks LIST        ENABLED_HOOKS allowlist (comma list, empty = all)
  --auth TOKEN        AUTH_TOKEN
  --idle-timeout SEC  STREAM_IDLE_TIMEOUT_SEC (default 30; 0 disables idle watchdog)
  --debug             DEBUG=true (debug-level logging) for start | restart | run
  --trace             DEBUG=true + CHAT_TRACE=true (debug + chat-trace NDJSON) for start | restart | run
  --env-file PATH     Override the default .env search
  --overrides-file PATH  Override the default overrides.env search

upgrade-env / migrate-to-overrides flags:
  --template PATH     Override the .env.example resolution
  --dest PATH         Override the resolved .env target (default: the
                      same path resolve_env_file would pick)
  --overrides-dest PATH (migrate-to-overrides) override the resolved overrides
                      target (default: sibling of --dest)
  --dry-run           Print added / orphaned / unchanged keys; write nothing
  --yes               Skip the overwrite confirmation prompt (CI-friendly)

init flags:
  --dest PATH         where to write the .env (default $GW_HOME/.env)
  --here              shortcut for --dest ./.env
  --force             overwrite if dest exists (on re-init: existing values
                      are preserved as defaults; secrets reused unchanged
                      unless --regenerate-secrets)
  --kiro PATH         skip the KIRO_CMD prompt
  --addr ADDR         skip the HTTP_ADDR prompt (default 127.0.0.1:18080)
  --pii MODE          skip the PII prompt (off|replace|mask|hash|drop|encrypt; default encrypt)
  --idle-timeout SEC  STREAM_IDLE_TIMEOUT_SEC override (default: write
                      "# STREAM_IDLE_TIMEOUT_SEC=30" commented; the binary
                      defaults to 30s anyway. Pass a value to write the
                      line uncommented. 0 disables the watchdog.)
  --auth-enabled      enable bearer-token auth (default off; AUTH_TOKEN line
                      pregenerated but commented when disabled, so flipping
                      the '#' enables it without re-running init)
  --auth-token TOK    use TOK instead of generating (implies --auth-enabled)
  --chat-trace        enable chat-trace NDJSON tracer (default off; records
                      raw user content -- sensitive)
  --regenerate-secrets  on re-init, mint fresh AUTH_TOKEN + PII_HASH_KEY.
                      Default behavior on re-init preserves existing values
                      to avoid invalidating clients / breaking hash-mode
                      log correlation. Use after a key leak.
  --hash-key KEY      use KEY instead of generating
  --encrypt-key KEY   operator-supplied PII_ENCRYPT_KEY for encrypt mode
                      (not minted; pass when --pii encrypt, or set
                      PII_ENCRYPT_KEY in the overrides file directly)
  --non-interactive   don't prompt; use defaults for unspecified values

.env auto-load search (loaded FIRST):
  1. --env-file PATH           (CLI override)
  2. $GW_ENV_FILE              (env override)
  3. ./.env                    (project-local)
  4. $GW_HOME/.env             (per-user)

overrides.env auto-load search (loaded SECOND; values win on conflict):
  1. --overrides-file PATH     (CLI override)
  2. $GW_OVERRIDES_FILE        (env override)
  3. ./overrides.env           (project-local)
  4. $GW_HOME/overrides.env    (per-user)

Precedence (highest first):
  CLI flag → overrides.env → .env → inherited shell env.

See scripts/.env.example for a starter template.
EOF
    else
        cat >&2 <<'EOF'
Usage: gw <command> [flags]

Commands:
  init [flags]        First-run setup — generates AUTH_TOKEN + PII_HASH_KEY,
                      prompts for KIRO_CMD + HTTP_ADDR, writes a .env file.
  start [flags]       Start gateway in background (waits for /health)
  stop                Stop background gateway (also reaps any stray $KIRO_CMD subprocesses)
  status              Show gateway status and health
  restart [flags]     Stop then start (re-applies flags / .env)
  logs [-f]           Tail gateway log (optional -f to follow)
  run [flags]         Run gateway in foreground
  env [--show-secrets]
                      Print the resolved gateway env that would be passed
  upgrade-env [flags] Regenerate .env from the latest .env.example
                      template. Operator customizations in overrides.env
                      are NEVER touched. --dry-run shows the added / orphaned /
                      unchanged keys without writing.
  migrate-to-overrides [flags]
                      One-time migration from the legacy single-file model:
                      extract non-default values from .env into
                      overrides.env, back up the original, then
                      regenerate .env from the template. Idempotent.
  version             Print the gateway binary version (delegates to bin/gateway --version)
  support [--out DIR] [--max-mb N] [--log-days D]
                      Produce a redacted diagnostic archive under
                      $GW_HOME/support/. Secrets are masked. No raw
                      values are ever written. See
                      docs/superpowers/specs/2026-06-08-support-bundle-design.md.

Gateway config flags (for start | restart | run | env):
  --pii MODE          off | replace | mask | hash | drop | encrypt
  --hash-key KEY      PII_HASH_KEY (required when --pii hash)
  --encrypt-key KEY   PII_ENCRYPT_KEY (required when --pii encrypt; any
                      non-empty string -- gateway derives a 32-byte
                      AES-256-GCM key via SHA-256 at boot)
  --entities LIST     PII_ENABLED_ENTITIES (comma list)
  --hooks LIST        ENABLED_HOOKS allowlist (comma list, empty = all)
  --auth TOKEN        AUTH_TOKEN
  --idle-timeout SEC  STREAM_IDLE_TIMEOUT_SEC (default 30; 0 disables idle watchdog)
  --debug             DEBUG=true (debug-level logging) for start | restart | run
  --trace             DEBUG=true + CHAT_TRACE=true (debug + chat-trace NDJSON) for start | restart | run
  --env-file PATH     Override the default .env search
  --overrides-file PATH  Override the default overrides.env search

upgrade-env / migrate-to-overrides flags:
  --template PATH     Override the .env.example resolution
  --dest PATH         Override the resolved .env target (default: the
                      same path resolve_env_file would pick)
  --overrides-dest PATH (migrate-to-overrides) override the resolved overrides
                      target (default: sibling of --dest)
  --dry-run           Print added / orphaned / unchanged keys; write nothing
  --yes               Skip the overwrite confirmation prompt (CI-friendly)

init flags:
  --dest PATH         where to write the .env (default $GW_HOME/.env)
  --here              shortcut for --dest ./.env
  --force             overwrite if dest exists (on re-init: existing values
                      are preserved as defaults; secrets reused unchanged
                      unless --regenerate-secrets)
  --kiro PATH         skip the KIRO_CMD prompt
  --addr ADDR         skip the HTTP_ADDR prompt (default 127.0.0.1:18080)
  --pii MODE          skip the PII prompt (off|replace|mask|hash|drop|encrypt; default encrypt)
  --idle-timeout SEC  STREAM_IDLE_TIMEOUT_SEC override (default: write
                      "# STREAM_IDLE_TIMEOUT_SEC=30" commented; the binary
                      defaults to 30s anyway. Pass a value to write the
                      line uncommented. 0 disables the watchdog.)
  --auth-enabled      enable bearer-token auth (default off; AUTH_TOKEN line
                      pregenerated but commented when disabled, so flipping
                      the '#' enables it without re-running init)
  --auth-token TOK    use TOK instead of generating (implies --auth-enabled)
  --chat-trace        enable chat-trace NDJSON tracer (default off; records
                      raw user content -- sensitive)
  --regenerate-secrets  on re-init, mint fresh AUTH_TOKEN + PII_HASH_KEY.
                      Default behavior on re-init preserves existing values
                      to avoid invalidating clients / breaking hash-mode
                      log correlation. Use after a key leak.
  --hash-key KEY      use KEY instead of generating
  --encrypt-key KEY   operator-supplied PII_ENCRYPT_KEY for encrypt mode
                      (not minted; pass when --pii encrypt, or set
                      PII_ENCRYPT_KEY in the overrides file directly)
  --non-interactive   don't prompt; use defaults for unspecified values

.env auto-load search (loaded FIRST):
  1. --env-file PATH           (CLI override)
  2. $GW_ENV_FILE              (env override)
  3. ./.env                    (project-local)
  4. $GW_HOME/.env             (per-user)

overrides.env auto-load search (loaded SECOND; values win on conflict):
  1. --overrides-file PATH     (CLI override)
  2. $GW_OVERRIDES_FILE        (env override)
  3. ./overrides.env           (project-local)
  4. $GW_HOME/overrides.env    (per-user)

Precedence (highest first):
  CLI flag → overrides.env → .env → inherited shell env.

See scripts/.env.example for a starter template.
EOF
    fi
    exit "$exit_code"
}

CMD="${1:-}"
if [[ -n "$CMD" ]]; then shift; fi
case "$CMD" in
    start|restart|run|env)
        parse_flags "$@"
        case "$CMD" in
            start)   start ;;
            restart) restart ;;
            run)     run ;;
            env)     print_env ;;
        esac
        ;;
    init)    init_cmd "$@" ;;
    stop)    stop ;;
    status)  status ;;
    logs)    logs "${1:-}" ;;
    version) show_version ;;
    support) support "$@" ;;
    upgrade-env) upgrade_env_cmd "$@" ;;
    migrate-to-overrides) migrate_to_overrides_cmd "$@" ;;
    help|-h|--help) usage 0 ;;
    *)       usage ;;
esac
